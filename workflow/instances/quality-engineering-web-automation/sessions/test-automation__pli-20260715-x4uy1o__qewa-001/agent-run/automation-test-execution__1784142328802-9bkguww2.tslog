[17:33:30] {"event": "tool_result", "tool": "view", "is_error": false, "result": {"status": "success", "file": "/Users/virginia.zambudio/PlaywrightAutomation/tests/home-page.spec.ts", "content": "88: // TC-83227  Home Page — Search returns relevant results\n89: // ADO TC: 83227 | Priority: P0 | Type: Positive\n90: // ---------------------------------------------------------------------------\n91: test(\n92:     'TC-83227 — Search returns relevant results for a valid term @search @positive @smoke',\n93:     async ({ page }) => {\n94:         const homePage = new HomePage(page);\n95:         const searchResultsPage = new SearchResultsPage(page);\n96: \n97:         await test.step('Navigate to homepage', async () => {\n98:             await homePage.navigate(homePageData.urls.home);\n99:         });\n100: \n101:         await test.step('Click page body to unblock loading after search', async () => {\n102:             await page.locator('body').click({ force: true });\n103:         });\n104: \n105:         await test.step('Wait for search input to be ready', async () => {\n106:             await homePage.waitForSearchInput();\n107:         });\n108: \n109:         await test.step('Click search input field', async () => {\n110:             await homePage.searchInput.click();\n111:         });\n112: \n113:         await test.step('Type search term', async () => {\n114:             await homePage.searchInput.fill(homePageData.search.validTerm);\n115:         });\n116: \n117:         await test.step('Submit search by pressing Enter', async () => {\n118:             await homePage.searchInput.press('Enter');\n119:         });\n120: \n121:         await test.step('Click page body to unblock loading after search', async () => {\n122:             await page.locator('body').click({ force: true });\n123:         });\n124: \n125:         await test.step('Verify search term appears in a product title or section heading', async () => {\n126:             const matchingHeadings = searchResultsPage.headingsMatching(homePageData.search.validTerm);\n127:             await expect(matchingHeadings.first()).toBeVisible({ timeout: 30_000 });\n128:             await expect(matchingHeadings).not.toHaveCount(0);\n129:         });\n130:     }\n131: );\n132: \n133: // ---------------------------------------------------------------------------\n134: // TC-83228  Home Page — Store Locator opens and allows search\n135: // ADO TC: 83228 | Priority: P1 | Type: Positive\n136: // Note: Google Maps iframe is blocked — test validates heading and list only.\n137: // ---------------------------------------------------------------------------"}}
