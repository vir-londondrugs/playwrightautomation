[17:48:49] {"event": "tool_result", "tool": "edit", "is_error": false, "result": {"status": "success", "file": "/Users/virginia.zambudio/PlaywrightAutomation/tests/pdp.spec.ts", "message": "The file /Users/virginia.zambudio/PlaywrightAutomation/tests/pdp.spec.ts has been edited.\nHere's the result of running `cat -n` on a snippet of /Users/virginia.zambudio/PlaywrightAutomation/tests/pdp.spec.ts:\n   147\t// TC-83238  PDP — Add to cart with In-Store Pickup using postal code V6B 1A1\n   148\t//           increments mini cart counter\n   149\t// ADO TC: 83238 | Priority: P1 | Type: Positive\n   150\t// ---------------------------------------------------------------------------\n   151\ttest(\n   152\t    'TC-83238 — Add to cart with In-Store Pickup (postal V6B 1A1) increments mini cart counter @pdp @cart @in-store-pickup',\n   153\t    async ({ page }) => {\n   154\t        // Extended timeout: store-selector search can take up to 30 s on UAT across all browsers.\n   155\t        // Total flow: navigate (20 s) + scroll/open dialog (15 s) + search (30 s) + add-to-cart (20 s) = ~85 s.\n   156\t        test.setTimeout(150_000);\n   157\t\n   158\t        const homePage = new HomePage(page);\n   159\t        const searchResultsPage = new SearchResultsPage(page);\n   160\t        const pdpPage = new ProductDetailPage(page);\n   161\t\n   162\t        await test.step('Navigate to a vitamins product detail page via search', async () => {\n   163\t            await navigateToVitaminsPdp(page, homePage, searchResultsPage);\n   164\t        });\n   165\t\n   166\t        await test.step('Read current mini cart badge count before adding to cart', async () => {\n   167\t            // Count may be 0 (badge hidden) or N (existing items).\n   168\t            // Captured as a baseline to confirm increment after Add to Cart.\n   169\t            // (count captured in the assertion step below via getMiniCartCount)\n   170\t        });\n   171\t\n   172\t        const countBefore = await pdpPage.getMiniCartCount();\n   173\t\n   174\t        await test.step('Open store selector dialog and set store using postal code V6B 1A1', async () => {\n   175\t            await pdpPage.openStoreSelectorDialog();\n   176\t        });\n   177\t\n   178\t        await test.step('Search for stores using postal code V6B 1A1', async () => {\n   179\t            await pdpPage.searchStores(pdpData.postalCode);\n   180\t        });\n   181\t\n   182\t        await test.step('Select the first store from results', async () => {\n   183\t            await pdpPage.selectFirstStore();\n   184\t        });\n   185\t\n   186\t        await test.step('Verify In-Store Pickup is now selected (fulfillment changed)', async () => {\n   187\t            // After selecting a store, In-Store Pickup radio is checked automatically\n   188\t            await pdpPage.inStorePickupRadio.waitFor({ state: 'attached', timeout: 30_000 });\n   189\t            await expect(pdpPage.inStorePickupRadio).toBeChecked({ timeout: 30_000 });\n   190\t        });\n   191\t\n   192\t        await test.step('Click ADD TO CART with In-Store Pickup fulfillment', async () => {\n   193\t            await pdpPage.addToCart();\n   194\t        });\n   195\t\n   196\t        await test.step('Verify mini cart badge counter incremented by 1', async () => {\n   197\t            const countAfter = await pdpPage.getMiniCartCount();\n   198\t            expect(countAfter).toBe(countBefore + 1);\n   199\t        });\n   200\t    }\n   201\t);\n   202\t\n   203\t// ---------------------------------------------------------------------------\n   204\t// TC-83239  PDP — Add to cart with Ship to Home using postal code V6B 1A1\n   205\t//           increments cart counter\n   206\t// ADO TC: 83239 | Priority: P1 | Type: Positive\n   207\t// ---------------------------------------------------------------------------\n   208\ttest(\n   209\t    'TC-83239 — Add to cart with Ship to Home (postal V6B 1A1) increments cart counter @pdp @cart @ship-to-home',\n   210\t    async ({ page }) => {\n   211\t        const homePage = new HomePage(page);\n   212\t        const searchResultsPage = new SearchResultsPage(page);\n   213\t        const pdpPage = new ProductDetailPage(page);\n   214\t\n   215\t        await test.step('Navigate to a vitamins product detail page via search', async () => {\n   216\t            await navigateToVitaminsPdp(page, homePage, searchResultsPage);\n   217\t        });\n   218\t\n   219\t        const countBefore = await pdpPage.getMiniCartCount();\n   220\t\n   221\t        await test.step('Open the delivery location modal via \"Change Postal Code\" link', async () => {\n   222\t            await pdpPage.openDeliveryLocationModal();\n   223\t        });\n   224\t\n   225\t        await test.step('Fill postal code V6B 1A1 and submit', async () => {\n   226\t            await pdpPage.setDeliveryPostalCode(pdpData.postalCode);\n   227\t        });\n   228\t\n   229\t        await test.step('Ensure Ship to Home fulfillment is selected', async () => {\n   230\t            // Ship to Home is the default option; after setting postal code it should remain selected.\n   231\t            // If In-Store Pickup became active, explicitly select Ship to Home.\n   232\t            const homeRadioChecked = await pdpPage.shipToHomeRadio.isChecked().catch(() => false);\n   233\t            if (!homeRadioChecked) {\n   234\t                await pdpPage.shipToHomeRadio.click();\n   235\t            }\n   236\t            await expect(pdpPage.shipToHomeRadio).toBeChecked({ timeout: 30_000 });\n   237\t        });\n   238\t\n   239\t        await test.step('Click ADD TO CART with Ship to Home fulfillment', async () => {\n   240\t            await pdpPage.addToCart();\n   241\t        });\n   242\t\n   243\t        await test.step('Verify cart counter incremented by 1', async () => {\n   244\t            const countAfter = await pdpPage.getMiniCartCount();\n   245\t            expect(countAfter).toBe(countBefore + 1);\n   246\t        });\n   247\t    }\n   248\t);\n   249\t\n   250\t// ---------------------------------------------------------------------------\n   251\t// TC-83240  PDP — Authenticated user clicks heart icon to add product to\n   252\t//           wishlist and API call confirms the action\n   253\t// ADO TC: 83240 | Priority: P1 | Type: Positive\n   254\t//\n   255\t// Precondition: Valid test account credentials are available.\n   256\t// Credentials are read from environment variables (see pdp.data.ts):\n   257\t//   TEST_USER_EMAIL / TEST_USER_PASSWORD\n   258\t// ---------------------------------------------------------------------------\n   259\ttest(\n   260\t    'TC-83240 — Authenticated user adds product to wishlist and API call confirms the action @pdp @wishlist @authenticated',\n   261\t    async ({ page }) => {\n   262\t        const loginPage = new LoginPage(page);\n   263\t        const homePage = new HomePage(page);\n   264\t        const searchResultsPage = new SearchResultsPage(page);\n   265\t        const pdpPage = new ProductDetailPage(page);\n   266\t\n   267\t        // ── Precondition: Log in ────────────────────────────────────────────\n   268\t        await test.step('Log in with test user credentials', async () => {\n   269\t            await loginPage.login(pdpData.auth.email, pdpData.auth.password);\n   270\t        });\n   271\t\n   272\t        // ── Navigate to a vitamins PDP ──────────────────────────────────────\n   273\t        await test.step('Navigate to a vitamins product detail page via search', async () => {\n   274\t            await navigateToVitaminsPdp(page, homePage, searchResultsPage);\n   275\t        });\n   276\t\n   277\t        await test.step('Verify the wishlist heart button is visible', async () => {\n   278\t            await pdpPage.wishlistButton.waitFor({ state: 'visible', timeout: 30_000 });\n   279\t        });\n   280\t\n   281\t        // ── Intercept wishlist API call and click heart ─────────────────────\n   282\t        await test.step('Click the heart icon and confirm the wishlist API call is made', async () => {\n   283\t            // Set up a response promise BEFORE clicking so we don't miss fast responses.\n   284\t            // The UAT site uses Next.js server actions; wishlist operations POST to the\n   285\t            // current PDP URL with action payload, returning JSON with isSuccess: true.\n   286\t            // We wait for ANY POST to the current page URL that returns a 200 response.\n   287\t            const wishlistResponsePromise = page.waitForResponse(\n   288\t                (response) =>\n   289\t                    response.request().method() === 'POST' &&\n   290\t                    response.url().includes('/products/') &&\n   291\t                    response.status() === 200,\n   292\t                { timeout: 30_000 }\n   293\t            );\n   294\t\n   295\t            await pdpPage.wishlistButton.click();\n   296\t\n   297\t            // Wait for the API response confirming the wishlist action was processed\n   298\t            const response = await wishlistResponsePromise;\n   299\t            expect(response.status()).toBe(200);\n   300\t\n   301\t            // Optionally parse the response body to verify isSuccess: true\n   302\t            let body: string | null = null;\n   303\t            try {\n   304\t                body = await response.text();\n   305\t            } catch {\n   306\t                // Body may be binary or already consumed; skip body check\n   307\t            }\n   308\t            if (body && body.includes('isSuccess')) {\n   309\t                expect(body).toMatch(/isSuccess.*true/i);\n   310\t            }\n   311\t        });\n   312\t    }\n   313\t);\n   314\t\n Review the changes and make sure they are as expected. Edit the file again if necessary.", "diff": ["│ --- before /Users/virginia.zambudio/PlaywrightAutomation/tests/pdp.spec.ts", "│ +++ after /Users/virginia.zambudio/PlaywrightAutomation/tests/pdp.spec.ts", "│ @@ -151,6 +151,10 @@", "│  test(\n", "│      'TC-83238 — Add to cart with In-Store Pickup (postal V6B 1A1) increments mini cart counter @pdp @cart @in-store-pickup',\n", "│      async ({ page }) => {\n", "│ +        // Extended timeout: store-selector search can take up to 30 s on UAT across all browsers.\n", "│ +        // Total flow: navigate (20 s) + scroll/open dialog (15 s) + search (30 s) + add-to-cart (20 s) = ~85 s.\n", "│ +        test.setTimeout(150_000);\n", "│ +\n", "│          const homePage = new HomePage(page);\n", "│          const searchResultsPage = new SearchResultsPage(page);\n", "│          const pdpPage = new ProductDetailPage(page);\n"]}}
