[18:19:58] {"event": "tool_result", "tool": "edit", "is_error": false, "result": {"status": "success", "file": "/Users/virginia.zambudio/PlaywrightAutomation/tests/plp.spec.ts", "message": "The file /Users/virginia.zambudio/PlaywrightAutomation/tests/plp.spec.ts has been edited.\nHere's the result of running `cat -n` on a snippet of /Users/virginia.zambudio/PlaywrightAutomation/tests/plp.spec.ts:\n   123\t// ---------------------------------------------------------------------------\n   124\t// TC FTC_02_01_02 -- Multiple filters narrow results\n   125\t// Priority: P1 | Type: Positive\n   126\t// ---------------------------------------------------------------------------\n   127\ttest(\n   128\t    'FTC_02_01_02 -- Applying multiple filters on lipstick search narrows results @plp @filter @positive',\n   129\t    async ({ page }) => {\n   130\t        // Extended timeout: applying sequential filters involves multiple API calls that can\n   131\t        // take >60 s on Firefox/WebKit when running under parallel UAT load.\n   132\t        test.setTimeout(120_000);\n   133\t\n   134\t        const homePage = new HomePage(page);\n   135\t        const searchResultsPage = new SearchResultsPage(page);\n   136\t\n   137\t        await test.step('Navigate to lipstick PLP', async () => {\n   138\t            await navigateToPLP(page, homePage, searchResultsPage, plpData.searchTerms.lipstick);\n   139\t        });\n   140\t\n   141\t        await test.step('Wait for filter drawer trigger to be visible', async () => {\n   142\t            await searchResultsPage.filterTrigger.first().waitFor({ state: 'visible', timeout: 30_000 });\n   143\t        });\n   144\t\n   145\t        // OQ-01 extended: filter apply redirects to www.londondrugs.com on UAT.\n   146\t        await interceptAndAbortFilterRedirect(page);\n   147\t\n   148\t        const urlBefore = page.url();\n   149\t\n   150\t        await test.step('Open filter drawer and apply first filter', async () => {\n   151\t            await searchResultsPage.openFilterDrawer();\n   152\t            await searchResultsPage.clickFilterCheckbox(0);\n   153\t            await searchResultsPage.applyFilters().catch(() => {});\n   154\t        });\n   155\t\n   156\t        await test.step('Assert URL changed after first filter applied', async () => {\n   157\t            expect(page.url()).not.toBe(urlBefore);\n   158\t        });\n   159\t\n   160\t        const urlAfterFirstFilter = page.url();\n   161\t\n   162\t        await test.step('Open filter drawer again and apply a second filter', async () => {\n   163\t            await searchResultsPage.openFilterDrawer();\n   164\t            // Attempt second checkbox; skip gracefully if only one available.\n   165\t            const checkboxCount = await searchResultsPage.filterCheckboxes.count();\n   166\t            if (checkboxCount >= 2) {\n   167\t                await searchResultsPage.clickFilterCheckbox(1);\n   168\t                await searchResultsPage.applyFilters().catch(() => {});\n   169\t                // Second URL should differ from first-filter URL (additional param).\n   170\t                const urlAfterSecondFilter = page.url();\n   171\t                expect(urlAfterSecondFilter).not.toBe(urlAfterFirstFilter);\n   172\t            } else {\n   173\t                test.skip(true, 'Only one filter available on lipstick PLP; second-filter step skipped.');\n   174\t            }\n   175\t        });\n   176\t    },\n   177\t);\n   178\t\n   179\t// ---------------------------------------------------------------------------\n   180\t// TC FTC_02_01_03 -- Filter panel presence (graceful degradation check)\n   181\t// Priority: P1 | Type: Negative\n   182\t// ---------------------------------------------------------------------------\n   183\ttest(\n   184\t    'FTC_02_01_03 -- Filter panel is present on lipstick PLP and page loads without error @plp @filter @negative',\n   185\t    async ({ page }) => {\n   186\t        const homePage = new HomePage(page);\n   187\t        const searchResultsPage = new SearchResultsPage(page);\n   188\t\n   189\t        await test.step('Navigate to lipstick PLP', async () => {\n   190\t            await navigateToPLP(page, homePage, searchResultsPage, plpData.searchTerms.lipstick);\n   191\t        });\n   192\t\n   193\t        await test.step('Assert filter trigger (drawer button) is present', async () => {\n   194\t            // Graceful degradation: assert filter panel renders with at least 1 trigger.\n   195\t            await expect(searchResultsPage.filterTrigger.first()).toBeVisible({ timeout: 30_000 });\n   196\t        });\n   197\t\n   198\t        await test.step('Assert page loaded without a JavaScript error heading', async () => {\n   199\t            // Verify no 500/error heading (h1 containing \"Error\" or \"Something went wrong\").\n   200\t            const errorHeading = page.locator('h1').filter({ hasText: /error|something went wrong/i });\n   201\t            await expect(errorHeading).toHaveCount(0);\n   202\t        });\n   203\t    },\n   204\t);\n   205\t\n   206\t// ---------------------------------------------------------------------------\n   207\t// TC FTC_02_01_04 -- Removing filter restores full results\n   208\t// Priority: P1 | Type: Negative\n   209\t// ---------------------------------------------------------------------------\n   210\ttest(\n   211\t    'FTC_02_01_04 -- Removing applied filter on lipstick PLP restores full results and clears filter URL param @plp @filter @negative',\n   212\t    async ({ page }) => {\n   213\t        // Extended timeout: filter apply + network round-trip + re-render takes >60 s on Firefox/WebKit on UAT.\n   214\t        test.setTimeout(120_000);\n   215\t\n   216\t        const homePage = new HomePage(page);\n   217\t        const searchResultsPage = new SearchResultsPage(page);\n   218\t\n   219\t        // OQ-01 extended: filter apply redirects to www.londondrugs.com on UAT.\n   220\t        await interceptAndAbortFilterRedirect(page);\n   221\t\n   222\t        await test.step('Navigate to lipstick PLP and apply first filter', async () => {\n   223\t            await navigateToPLP(page, homePage, searchResultsPage, plpData.searchTerms.lipstick);\n   224\t            await searchResultsPage.filterTrigger.first().waitFor({ state: 'visible', timeout: 30_000 });\n   225\t            await searchResultsPage.openFilterDrawer();\n   226\t            await searchResultsPage.clickFilterCheckbox(plpData.filter.firstCheckboxIndex);\n   227\t            await searchResultsPage.applyFilters().catch(() => {});\n   228\t        });\n   229\t\n   230\t        const urlWithFilter = page.url();\n   231\t\n   232\t        await test.step('Open filter drawer and uncheck the applied filter', async () => {\n   233\t            await searchResultsPage.openFilterDrawer();\n   234\t            // Uncheck the same checkbox that was applied (index 0).\n   235\t            await searchResultsPage.clickFilterCheckbox(plpData.filter.firstCheckboxIndex);\n   236\t        });\n   237\t\n   238\t        await test.step('Assert: URL no longer contains the filter parameter after clearing', async () => {\n   239\t            // Try clicking Clear button first; if unavailable, apply with checkbox unchecked.\n   240\t            const clearVisible = await searchResultsPage.clearFiltersButton.isVisible().catch(() => false);\n   241\t            if (clearVisible) {\n   242\t                await searchResultsPage.clearFilters().catch(() => {});\n   243\t            } else {\n   244\t                await searchResultsPage.applyFilters().catch(() => {});\n   245\t            }\n   246\t            const urlAfterClear = page.url();\n   247\t            // URL should differ from the filtered URL (filter param removed).\n   248\t            expect(urlAfterClear).not.toBe(urlWithFilter);\n   249\t        });\n   250\t    },\n   251\t);\n   252\t\n   253\t// ---------------------------------------------------------------------------\n   254\t// TC-83234 / FTC_02_02_01 -- PLP Sort: Price Low to High\n   255\t// ADO TC: 83234 | Priority: P2 | Type: Positive\n   256\t// CSV: \"Selecting 'Price: Low to High' sort on vitamins search triggers API\n   257\t//       call and reflects sort in URL\"\n   258\t// Steps (from CSV UAT Regression Master Plan):\n   259\t//   1. Navigate to vitamins search URL\n   260\t//   2. Wait for sort control to load\n   261\t//   3. Select 'Price: Low to High' sorting option\n   262\t//   4. Wait for sorted results API response\n   263\t//   Assert: URL reflects active sort = True\n   264\t// OQ-01: Sort may redirect to www.londondrugs.com (production).\n   265\t//   interceptAndAbortSortRedirect() handles the cross-domain redirect.\n   266\t// ---------------------------------------------------------------------------\n   267\ttest(\n   268\t    \"TC-83234 FTC_02_02_01 -- Selecting 'Price: Low to High' sort on vitamins search triggers API call and reflects sort in URL @plp @sort @positive\",\n   269\t    async ({ page }) => {\n   270\t        const homePage = new HomePage(page);\n   271\t        const searchResultsPage = new SearchResultsPage(page);\n   272\t\n   273\t        await test.step('Step 1: Navigate to vitamins search and wait for PLP to load', async () => {\n   274\t            // CSV step 1: \"Navigate to https://www.londondrugs.com/search?text=vitamins\"\n   275\t            await navigateToPLP(page, homePage, searchResultsPage, plpData.searchTerms.vitamins);\n   276\t        });\n   277\t\n   278\t        await test.step('Step 2: Wait for sort control to be visible', async () => {\n   279\t            // CSV step 2: \"Wait for sort control to load\"\n   280\t            await searchResultsPage.sortButton.waitFor({ state: 'visible', timeout: 30_000 });\n   281\t        });\n   282\t\n   283\t        // OQ-01: intercept sort redirect to production URL before triggering sort.\n   284\t        await interceptAndAbortSortRedirect(page);\n   285\t\n   286\t        const urlBefore = page.url();\n   287\t\n   288\t        await test.step(\"Step 3: Open sort overlay and select 'Price: Low to High' option\", async () => {\n   289\t            // CSV step 3: \"Select 'Price: Low to High' sorting option\"\n   290\t            await searchResultsPage.openSortOverlay();\n   291\t            // Index 1 = \"Price: Low to High\" (index 0 = default/relevance).\n   292\t            await searchResultsPage.selectSortOption(plpData.sort.priceLowToHighIndex);\n   293\t        });\n   294\t\n   295\t        await test.step('Step 4: Wait for sorted results API response / URL update', async () => {\n   296\t            // CSV step 4: \"Wait for sorted results API response\"\n   297\t            // Wait for URL to update with sort parameter (may differ from pre-sort URL).\n   298\t            await page.waitForURL(\n   299\t                (url) => url.toString() !== urlBefore,\n   300\t                { timeout: 30_000 },\n   301\t            ).catch(() => {\n   302\t                // If URL did not change (e.g. OQ-01 redirect aborted without URL update),\n   303\t                // continue; sort selection may have updated page state without URL change.\n   304\t            });\n   305\t        });\n   306\t\n   307\t        await test.step('Assert: URL reflects active sort (URL changed from baseline)', async () => {\n   308\t            // CSV expected: \"URL reflects active sort = True\"\n   309\t            // URL should contain sort parameter OR differ from baseline.\n   310\t            const urlAfter = page.url();\n   311\t            const urlChanged = urlAfter !== urlBefore;\n   312\t            const urlContainsSortParam =\n   313\t                urlAfter.includes('sort=') ||\n   314\t                urlAfter.includes(plpData.sort.priceLowHighParam);\n   315\t            // At least one of these must be true.\n   316\t            expect(urlChanged || urlContainsSortParam).toBe(true);\n   317\t        });\n   318\t    },\n   319\t);\n   320\t\n   321\t// ---------------------------------------------------------------------------\n   322\t// TC FTC_02_02_02 -- Sort control presence (graceful degradation check)\n   323\t// Priority: P2 | Type: Negative\n   324\t// ---------------------------------------------------------------------------\n   325\ttest(\n   326\t    'FTC_02_02_02 -- Sort control is present on vitamins PLP and page loads without error @plp @sort @negative',\n   327\t    async ({ page }) => {\n   328\t        const homePage = new HomePage(page);\n   329\t        const searchResultsPage = new SearchResultsPage(page);\n   330\t\n   331\t        await test.step('Navigate to vitamins PLP', async () => {\n   332\t            await navigateToPLP(page, homePage, searchResultsPage, plpData.searchTerms.vitamins);\n   333\t        });\n   334\t\n   335\t        await test.step('Assert sort button (overlay trigger) is visible', async () => {\n   336\t            await expect(searchResultsPage.sortButton).toBeVisible({ timeout: 30_000 });\n   337\t        });\n   338\t\n   339\t        await test.step('Assert page loaded without a JavaScript error heading', async () => {\n   340\t            const errorHeading = page.locator('h1').filter({ hasText: /error|something went wrong/i });\n   341\t            await expect(errorHeading).toHaveCount(0);\n   342\t        });\n   343\t    },\n   344\t);\n   345\t\n   346\t// ---------------------------------------------------------------------------\n   347\t// TC FTC_02_02_03 -- Switch sort order from Low-to-High to High-to-Low\n   348\t// Priority: P2 | Type: Boundary\n   349\t// ---------------------------------------------------------------------------\n   350\ttest(\n   351\t    \"FTC_02_02_03 -- Switching sort from 'Price: Low to High' to 'Price: High to Low' updates URL @plp @sort @boundary\",\n   352\t    async ({ page }) => {\n   353\t        const homePage = new HomePage(page);\n   354\t        const searchResultsPage = new SearchResultsPage(page);\n   355\t\n   356\t        await test.step('Navigate to vitamins PLP', async () => {\n   357\t            await navigateToPLP(page, homePage, searchResultsPage, plpData.searchTerms.vitamins);\n   358\t        });\n   359\t\n   360\t        await test.step('Wait for sort control to be visible', async () => {\n   361\t            await searchResultsPage.sortButton.waitFor({ state: 'visible', timeout: 30_000 });\n   362\t        });\n   363\t\n   364\t        // OQ-01: intercept sort redirect to production URL.\n   365\t        await interceptAndAbortSortRedirect(page);\n   366\t\n   367\t        await test.step(\"Apply 'Price: Low to High' sort first\", async () => {\n   368\t            await searchResultsPage.openSortOverlay();\n   369\t            await searchResultsPage.selectSortOption(plpData.sort.priceLowToHighIndex);\n   370\t            // Wait for sort overlay to close (options disappear) before re-opening.\n   371\t            await searchResultsPage.sortOptions.first().waitFor({ state: 'hidden', timeout: 5_000 }).catch(() => {});\n   372\t        });\n   373\t\n   374\t        const urlAfterLowHigh = page.url();\n   375\t\n   376\t        await test.step(\"Switch to 'Price: High to Low' sort\", async () => {\n   377\t            // Re-open sort overlay and pick the high-to-low option.\n   378\t            await searchResultsPage.openSortOverlay();\n   379\t            await searchResultsPage.selectSortOption(plpData.sort.priceHighToLowIndex);\n   380\t        });\n   381\t\n   382\t        await test.step('Assert URL updated after sort switch', async () => {\n   383\t            await page.waitForURL(\n   384\t                (url) => url.toString() !== urlAfterLowHigh,\n   385\t                { timeout: 30_000 },\n   386\t            ).catch(() => {});\n   387\t            const urlAfterHighLow = page.url();\n   388\t            const sortChanged = urlAfterHighLow !== urlAfterLowHigh ||\n   389\t                urlAfterHighLow.includes(plpData.sort.priceHighLowParam);\n   390\t            expect(sortChanged).toBe(true);\n   391\t        });\n   392\t    },\n   393\t);\n   394\t\n Review the changes and make sure they are as expected. Edit the file again if necessary.", "diff": ["│ --- before /Users/virginia.zambudio/PlaywrightAutomation/tests/plp.spec.ts", "│ +++ after /Users/virginia.zambudio/PlaywrightAutomation/tests/plp.spec.ts", "│ @@ -127,6 +127,10 @@", "│  test(\n", "│      'FTC_02_01_02 -- Applying multiple filters on lipstick search narrows results @plp @filter @positive',\n", "│      async ({ page }) => {\n", "│ +        // Extended timeout: applying sequential filters involves multiple API calls that can\n", "│ +        // take >60 s on Firefox/WebKit when running under parallel UAT load.\n", "│ +        test.setTimeout(120_000);\n", "│ +\n", "│          const homePage = new HomePage(page);\n", "│          const searchResultsPage = new SearchResultsPage(page);\n", "│  \n"]}}
