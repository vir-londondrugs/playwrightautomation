[16:06:07] {"event": "tool_result", "tool": "view", "is_error": false, "result": {"status": "success", "file": "/Users/virginia.zambudio/PlaywrightAutomation/tests/home-page.spec.ts", "content": "390: \n391: // ---------------------------------------------------------------------------\n392: // TC-83232  Home Page — Newsletter signup in footer submits and redirects\n393: // ADO TC: 83232 | Priority: P1 | Type: Positive\n394: // The SIGN UP button submits via client-side navigation to:\n395: //   /enewsletter-settings?email=<encoded_email>\n396: // No confirmation message is shown on the homepage itself.\n397: // Verification: URL matches /enewsletter-settings after submit.\n398: // ---------------------------------------------------------------------------\n399: test(\n400:     'TC-83232 — Newsletter signup in footer accepts valid email and redirects to confirmation @newsletter @footer',\n401:     async ({ page }) => {\n402:         // Override the global 60 s timeout: Builder.io networkidle can take 30 s,\n403:         // the incremental scroll loop ~20 s, and the final waitFor 45 s. 180 s is safe.\n404:         test.setTimeout(180_000);\n405: \n406:         const homePage = new HomePage(page);\n407:         const { newsletter } = homePageData;\n408: \n409:         await test.step('Navigate to homepage', async () => {\n410:             await homePage.navigate(homePageData.urls.home);\n411:         });\n412: \n413:         await test.step('Scroll to footer newsletter form', async () => {\n414:             // The newsletter section is Builder.io-driven and is only rendered\n415:             // once its placeholder element enters the viewport (IntersectionObserver).\n416:             // A single jump to document.body.scrollHeight does NOT work because the\n417:             // page height at load time is small (~285px) — the newsletter placeholder\n418:             // is far below and the IntersectionObserver never fires.\n419:             //\n420:             // Strategy: incremental scrolling in viewport-height steps to ensure\n421:             // every Builder.io section's IntersectionObserver fires as the viewport\n422:             // passes over it. Between steps we wait 800 ms so lazy fetches complete.\n423:             // After the loop, fall back to scrollIntoViewIfNeeded + a final waitFor.\n424: \n425:             // First, let the page finish its initial network activity.\n426:             await page.waitForLoadState('networkidle', { timeout: 30_000 }).catch(() => {});\n427:             await page.waitForTimeout(1_000);\n428: \n429:             const viewportHeight = page.viewportSize()?.height ?? 800;\n430:             let scrollPosition = 0;\n431: \n432:             // Scroll in viewport-sized increments for up to 20 passes.\n433:             for (let pass = 0; pass < 20; pass++) {\n434:                 // Check if the element is already visible before scrolling further.\n435:                 const alreadyVisible = await homePage.newsletterEmailInput\n436:                     .isVisible()\n437:                     .catch(() => false);\n438:                 if (alreadyVisible) break;\n439: \n440:                 scrollPosition += viewportHeight;\n441:                 await page.evaluate((pos: number) => window.scrollTo(0, pos), scrollPosition);\n442:                 await page.waitForTimeout(800);\n443: \n444:                 // If we have scrolled past the current page bottom, restart from\n445:                 // the top so Builder.io's lazy sections re-evaluate their position.\n446:                 const currentScrollHeight = await page.evaluate(\n447:                     () => document.body.scrollHeight\n448:                 );\n449:                 if (scrollPosition >= currentScrollHeight) {\n450:                     scrollPosition = 0;\n451:                     await page.evaluate(() => window.scrollTo(0, 0));\n452:                     await page.waitForTimeout(500);\n453:                 }\n454:             }\n455: \n456:             // Belt-and-suspenders: ask Playwright to scroll the element into view\n457:             // if it is already in the DOM but not yet in the viewport.\n458:             await homePage.newsletterEmailInput\n459:                 .scrollIntoViewIfNeeded({ timeout: 5_000 })\n460:                 .catch(() => undefined);\n461: \n462:             // Final authoritative wait. By this point the element should be\n463:             // visible; the 45 s window covers any remaining Builder.io fetch delay.\n464:             await homePage.newsletterEmailInput.waitFor({ state: 'visible', timeout: 45_000 });\n465:         });\n466: \n467:         await test.step('Fill valid email in newsletter input', async () => {\n468:             await homePage.newsletterEmailInput.fill(newsletter.testEmail);\n469:         });"}}
