[17:33:40] {"event": "tool_result", "tool": "view", "is_error": false, "result": {"status": "success", "file": "/Users/virginia.zambudio/PlaywrightAutomation/pages/SearchResultsPage.ts", "content": "130:     /**\n131:      * Returns headings (h2 section names or h3 product titles) within the\n132:      * main content area that contain the given search term.\n133:      * Covers both cases: term appears in a product name OR in a section heading.\n134:      */\n135:     headingsMatching(term: string): Locator {\n136:         return this.page.locator('main h2, main h3').filter({ hasText: new RegExp(term, 'i') });\n137:     }\n138: \n139:     // ---- New PLP filter methods ------------------------------------------------\n140: \n141:     /**\n142:      * Waits for the results heading to be visible after a search.\n143:      * Reliable indicator that the PLP has rendered product results.\n144:      *\n145:      * @param timeoutMs - Maximum ms to wait. Default 30 000 ms.\n146:      */\n147:     async waitForResultsHeading(timeoutMs: number = 30_000): Promise<void> {\n148:         await this.resultsHeading.waitFor({ state: 'visible', timeout: timeoutMs });\n149:     }"}}
