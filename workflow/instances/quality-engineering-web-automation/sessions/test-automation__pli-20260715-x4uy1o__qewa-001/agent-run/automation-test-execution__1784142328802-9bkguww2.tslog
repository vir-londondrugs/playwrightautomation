timeout: 30_000 });\n166:         });\n167: \n168:         await test.step(\"Click 'Find All Stores by Province' link\", async () => {\n169:             await storeLocatorPage.allStoresLink.waitFor({ state: 'visible', timeout: 30_000 });\n170:             await storeLocatorPage.allStoresLink.click();\n171:         });\n172: \n173:         await test.step('Wait for All Stores URL', async () => {\n174:             await page.waitForURL('**/stores/all-stores', { timeout: 30_000 });\n175:             // Allow Next.js SPA to finish client-side rendering of province sections after URL change.\n176:             // The /stores/all-stores page only renders province content via SPA navigation;\n177:             // a direct full-page load shows only a loading spinner.\n178:             await page.waitForLoadState('domcontentloaded', { timeout: 30_000 }).catch(() => {});\n179:         });\n180: \n181:         await test.step('Verify All Stores list is visible', async () => {\n182:             // storeList matches the first province heading (e.g. \"British Columbia\").\n183:             // toBeVisible() retries for up to 20 s to handle React hydration delay after SPA navigation.\n184:             await expect(storeLocatorPage.storeList).toBeVisible({ timeout: 30_000 });\n185:         });\n186:     }\n187: );\n188: \n189: // ---------------------------------------------------------------------------\n190: // TC-83229  Home Page — Mini Cart opens and View Cart navigates to cart\n191: // ADO TC: 83229 | Priority: P1 | Type: Positive\n192: // Precondition: 1 product is added to cart inline as part of this test setup.\n193: // Fix notes:\n194: //   - miniCartPanel selector updated: UAT uses absolute+z-50 div, no \"miniCart\" class token.\n195: //   - CTA button text on UAT is \"View Cart\", not \"Proceed to Checkout\".\n196: // ---------------------------------------------------------------------------\n197: test(\n198:     'TC-83229 — Mini Cart opens and View Cart navigates to cart page @mini-cart @cart @navigation',\n199:     async ({ page }) => {\n200:         const homePage = new HomePage(page);\n201:         const searchResultsPage = new SearchResultsPage(page);\n202:         const { miniCart } = homePageData;\n203: \n204:         // productName is captured dynamically at runtime from the product page h1.\n205:         // This avoids any hardcoded SKU or product name that could break when the\n206:         // catalog changes. It is populated in the precondition steps below.\n207:         let productName = '';\n208: \n209:         // ── Precondition: find a product via search and add it to the cart ────\n210:         await test.step('Search for a product and navigate to the first result', async () => {\n211:             // Search results only render after React/Builder.io hydration — navigating\n212:             // directly to the search URL produces a blank page. Use the search UI instead\n213:             // (same approach as TC-83226) so client-side routing renders the results.\n214:             await homePage.navigate(homePageData.urls.home);\n215:             await page.locator('body').click({ force: true });\n216:             await homePage.waitForSearchInput();\n217:             await homePage.search(miniCart.searchTerm);\n218:             await page.waitForURL(/\\/search/, { timeout: 30_000 });\n219:             // Wait for product results to render, then click the first one.\n220:             await searchResultsPage.firstProductLink.waitFor({ state: 'visible', timeout: 30_000 });\n221:             await searchResultsPage.firstProductLink.click();\n222:             // Wait until the browser has left the search page and landed on the product page.\n223:             await page.waitForURL((url) => !url.pathname.includes('/search'), { timeout: 30_000 });\n224:             await page.waitForLoadState('domcontentloaded');\n225:         });\n226: \n227:         await test.step('Capture product name from product page', async () => {\n228:  