[13:51:14] {"event": "tool_result", "tool": "view", "is_error": false, "result": {"status": "success", "file": "/Users/virginia.zambudio/PlaywrightAutomation/tests/pdp.spec.ts", "content": "151: test(\n152:     'TC-83238 — Add to cart with In-Store Pickup (postal V6B 1A1) increments mini cart counter @pdp @cart @in-store-pickup',\n153:     async ({ page }) => {\n154:         const homePage = new HomePage(page);\n155:         const searchResultsPage = new SearchResultsPage(page);\n156:         const pdpPage = new ProductDetailPage(page);\n157: \n158:         await test.step('Navigate to a vitamins product detail page via search', async () => {\n159:             await navigateToVitaminsPdp(page, homePage, searchResultsPage);\n160:         });\n161: \n162:         await test.step('Read current mini cart badge count before adding to cart', async () => {\n163:             // Count may be 0 (badge hidden) or N (existing items).\n164:             // Captured as a baseline to confirm increment after Add to Cart.\n165:             // (count captured in the assertion step below via getMiniCartCount)\n166:         });\n167: \n168:         const countBefore = await pdpPage.getMiniCartCount();\n169: \n170:         await test.step('Open store selector dialog and set store using postal code V6B 1A1', async () => {\n171:             await pdpPage.openStoreSelectorDialog();\n172:         });\n173: \n174:         await test.step('Search for stores using postal code V6B 1A1', async () => {\n175:             await pdpPage.searchStores(pdpData.postalCode);\n176:         });\n177: \n178:         await test.step('Select the first store from results', async () => {\n179:             await pdpPage.selectFirstStore();\n180:         });\n181: \n182:         await test.step('Verify In-Store Pickup is now selected (fulfillment changed)', async () => {\n183:             // After selecting a store, In-Store Pickup radio is checked automatically\n184:             await pdpPage.inStorePickupRadio.waitFor({ state: 'attached', timeout: 30_000 });\n185:             await expect(pdpPage.inStorePickupRadio).toBeChecked({ timeout: 30_000 });\n186:         });\n187: \n188:         await test.step('Click ADD TO CART with In-Store Pickup fulfillment', async () => {\n189:             await pdpPage.addToCart();\n190:         });\n191: \n192:         await test.step('Verify mini cart badge counter incremented by 1', async () => {\n193:             const countAfter = await pdpPage.getMiniCartCount();\n194:             expect(countAfter).toBe(countBefore + 1);\n195:         });\n196:     }\n197: );\n198: \n199: // ---------------------------------------------------------------------------\n200: // TC-83239  PDP — Add to cart with Ship to Home using postal code V6B 1A1"}}
