--\n134: // TC-83228  Home Page — Store Locator opens and allows search\n135: // ADO TC: 83228 | Priority: P1 | Type: Positive\n136: // Note: Google Maps iframe is blocked — test validates heading and list only.\n137: // ---------------------------------------------------------------------------\n138: test(\n139:     'TC-83228 — Store Locator opens and Find All Stores link works @store-locator @navigation',\n140:     async ({ page }) => {\n141:         const homePage = new HomePage(page);\n142:         const storeLocatorPage = new StoreLocatorPage(page);\n143: \n144:         await test.step('Navigate to homepage', async () => {\n145:             await homePage.navigate(homePageData.urls.home);\n146:             await page.waitForLoadState('networkidle', { timeout: 8_000 }).catch(() => {});\n147:         });\n148: \n149:         await test.step('Click page body to unblock loading', async () => {\n150:             await page.locator('body').click({ force: true });\n151:         });\n152: \n153:         await test.step(\"Click 'Select Your Store' / stores link in header\", async () => {\n154:             await homePage.storesLink.waitFor({ state: 'visible', timeout: 30_000 });\n155:             await homePage.storesLink.click();\n156:         });\n157: \n158:         await test.step('Wait for Store Locator URL', async () => {\n159:             await page.waitForURL('**/stores', { timeout: 30_000 });\n160:             // Allow Next.js SPA to finish client-side rendering after URL change.\n161:             await page.waitForLoadState('domcontentloaded', { timeout: 30_000 }).catch(() => {});\n162:         });\n163: \n164:         await test.step(\"Verify 'Find a Store Near You' heading is visible\", async () => {\n165:             await expect(storeLocatorPage.heading).toBeVisible({ timeout: 30_000 });\n166:         });\n167: \n168:         await test.step(\"Click 'Find All Stores by Province' link\", async () => {\n169:             await storeLocatorPage.allStoresLink.waitFor({ state: 'visible', timeout: 30_000 });\n170:             await storeLocatorPage.allStoresLink.click();\n171:         });\n172: \n173:         await test.step('Wait for All Stores URL', async () => {\n174:             await page.waitForURL('**/stores/all-stores', { timeout: 30_000 });\n175:             // Allow Next.js SPA to finish client-side rendering of province sections after URL change.\n176:             // The /stores/all-stores page only renders province content via SPA navigation;\n177:             // a direct full-page load shows only a loading spinner.\n178:             await page.waitForLoadState('domcontentloaded', { timeout: 30_000 }).catch(() => {});\n179:         });\n180: \n181:         await test.step('Verify All Stores list is visible', async () => {\n182:             // storeList matches the first province heading (e.g. \"British Columbia\").\n183:             // toBeVisible() retries for up to 20 s to handle React hydration delay after SPA navigation.\n184:             await expect(storeLocatorPage.storeList).toBeVisible({ timeout: 30_000 });\n185:         });\n186:     }\n187: );\n188: \n189: // ---------------------------------------------------------------------------\n190: // TC-83229  Home Page — Mini Cart opens and View Cart navigates to cart\n191: // ADO TC: 83229 | Priority: P1 | Type: Positive\n192: // Precondition: 1 product is added to cart inline as part of this test setup.\n193: // Fix notes:\n194: //   - miniCartPanel selector updated: UAT uses absolute+z-50 div, no \"miniCart\" class token.\n195: //   - CTA button text on UAT is \"View Cart\", not \"Proceed to Checkout\".\n196: // ---------------------------------------------------------------------------\n197: test(\n198:     'TC-83229 — Mini Cart opens and View Cart navigates to cart page @mini-cart @cart @navigation',\n199:     async ({ page }) => {\n200:         const homePage = new HomePage(page);\n201:         const searchResultsPage = new SearchResultsPage(page);\n202:         const { miniCart } = homePageData;\n203: \n204:         // productName is captured dynamically at runtime from the product page h1.\n205:         // This avoids any hardcoded SKU or product name that could break when the\n206:         // catalog changes. It is populated in the precondition steps below.\n207:         let productName = '';\n208: \n209:         // ── Precondition: find a product via search and add it to the cart ────\n210:         await test.step('Search for a product and navigate to the first result', async () => {\n211:             // Search results only render after React/Builder.io hydration — navigating\n212:             // directly to the search URL produces a blank page. Use the search UI instead\n213:             // (same approach as TC-83226) so client-side routing renders the results.\n214:             await homePage.navigate(homePageData.urls.home);\n215:             await page.locator('body').click({ force: true });\n216:             await homePage.waitForSearchInput();\n217:             await homePage.search(miniCart.searchTerm);\n218:             await page.waitForURL(/\\/search/, { timeout: 30_000 });\n219:             // Wait for product results to render, then click the first one.\n220:             await searchResultsPage.firstProductLink.waitFor({ state: 'visible', timeout: 30_000 });\n221:             await searchResultsPage.firstProductLink.click();\n222:             // Wait until the browser has left the search page and landed on the product page.\n223:             await page.waitForURL((url) => !url.pathname.includes('/search'), { timeout: 30_000 });\n224:             await page.waitForLoadState('domcontentloaded');\n225:         });\n226: \n227:         await test.step('Capture product name from product page', async () => {\n228:             // Read the h1 heading on the product detail page.\n229:             // This is used later to verify the item appears in the cart.\n230:             const h1 = page.locator('h1').first();\n231:             await h1.waitFor({ state: 'visible', timeout: 30_000 });\n232:             productName = (await h1.textContent() ?? '').trim();\n233:         });\n234: \n235:         await test.step('Add product to cart', async () => {\n236:             const addToCartBtn = page.locator('button[aria-label=\"Add to cart button\"]');\n237:             await addToCartBtn.waitFor({ state: 'visible', timeout: 30_000 });\n238:             await addToCartBtn.click();\n239:         });\n240: \n241:         await test.step('Wait for View Cart & Checkout button and click it', async () => {\n242:             // After adding to cart the product page shows a \"View Cart & Checkout\" CTA.\n243:             // Waiting for it confirms the item was successfully added to the cart.\n244:             const viewCartCheckoutBtn = page.locator('button', { hasText: 'View Cart & Checkout' });\n245:             await viewCartCheckoutBtn.waitFor({ state: 'visible', timeout: 30_000 });\n246:             await viewCartCheckoutBtn.click();\n247:         });\n248: \n249:         await test.step('Wait for cart page to load', async () => {\n250:             await page.waitForURL(miniCart.expectedCartUrlRegex, { timeout: 30_000 });\n251:         });\n252:         // ── End precondition ──────────────────────────────────────────────────\n253: \n254:         await test.step('Navigate to homepage', async () => {\n255:             await homePage.navigate(homePageData.urls.home);\n256:         });\n257: \n258:         await test.step('Wait for homepage React hydration before interacting', async () => {\n259:             // waitForSearchInput() waits for the search input to be enabled, which is a\n260:             // reliable proxy for Builder.io/React hydration being complete on the homepage.\n261:             // Without this, clicking the mini cart button may be a no-op.\n262:             await page.locator('body').click({ force: true });\n263:             await homePage.waitForSearchInput();\n264:         });\n265: \n266:         await test.step('Wait for mini cart badge to show item count', async () => {\n267:             // The badge is a <div class=\"absolute bottom-1 left-8 ...\"> inside the cart\n268:             // icon button showing the number of items. Waiting for it ensures the cart\n269:             // state has been loaded from the API before opening the panel.\n270:             await page.locator('button[aria-label=\"Show Mini Cart Items\"] div[class*=\"bottom-1\"]')\n271:                 .first()\n272:                 .waitFor({ state: 'visible', timeout: 30_000 });\n273:         });\n274: \n275:         await test.step('Click mini cart icon in header', async () => {\n276:             await homePage.miniCartButton.waitFor({ state: 'visible', timeout: 30_000 });\n277:             await homePage.miniCartButton.click();\n278:         });\n279: \n280:         await test.step('Verify mini cart panel opens', async () => {\n281:             await expect(homePage.miniCartPanel).toBeVisible({ timeout: 30_000 });\n282:         });\n283: \n284:         await test.step(\"Click 'View Cart' button inside mini cart panel\", async () => {\n285:             await homePage.proceedToCheckoutButton.waitFor({ state: 'visible', timeout: 30_000 });\n286:             await homePage.proceedToCheckoutButton.click();\n287:         });\n288: \n289:         await test.step('Verify cart page opens and shows Cart heading', async () => {\n290:             await page.waitForURL(miniCart.expectedCartUrlRegex, { timeout: 30_000 });\n291:             await expect(page).toHaveURL(miniCart.expectedCartUrlRegex);\n292:             await expect(\n293:                 page.locator('h1').filter({ hasText: miniCart.cartPageHeading }).first()\n294:             ).toBeVisible({ timeout: 30_000 });\n295:         });\n296: \n297:         await test.step('Verify added product is listed in the cart', async () => {\n298:             // Cart items render as <a data-testid=\"cart:cart item\">