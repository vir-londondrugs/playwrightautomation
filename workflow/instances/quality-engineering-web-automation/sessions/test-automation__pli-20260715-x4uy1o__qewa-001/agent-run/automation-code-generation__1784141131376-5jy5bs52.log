{"event": "tool_result", "tool": "view", "is_error": false, "result": {"status": "success", "file": "/Users/virginia.zambudio/PlaywrightAutomation/tests/pdp.spec.ts", "content": "1: import { test, expect } from '@playwright/test';\n2: import { HomePage } from '../pages/HomePage';\n3: import { SearchResultsPage } from '../pages/SearchResultsPage';\n4: import { ProductDetailPage } from '../pages/ProductDetailPage';\n5: import { LoginPage } from '../pages/LoginPage';\n6: import { pdpData } from '../test-data/pdp.data';\n7: import { simulateBodyClickToUnblock } from '../helpers/page-load';\n8: import { takeEvidenceScreenshot } from '../helpers/evidence';\n9: \n10: // ---------------------------------------------------------------------------\n11: // Shared helper — navigate to a vitamins product detail page via search.\n12: // No product URL or name is hardcoded; the first result is used at runtime.\n13: // ---------------------------------------------------------------------------\n14: async function navigateToVitaminsPdp(\n15:     page: import('@playwright/test').Page,\n16:     homePage: HomePage,\n17:     searchResultsPage: SearchResultsPage,\n18: ): Promise<void> {\n19:     await homePage.navigate(pdpData.urls.home);\n20:     await simulateBodyClickToUnblock(page);\n21:     await homePage.waitForSearchInput();\n22:     await homePage.search(pdpData.vitaminsSearchTerm);\n23:     await page.waitForURL(/\\/search/, { timeout: 30_000 });\n24:     await simulateBodyClickToUnblock(page);\n25:     await searchResultsPage.firstProductLink.waitFor({ state: 'visible', timeout: 30_000 });\n26:     await searchResultsPage.firstProductLink.click();\n27:     await page.waitForURL((url) => !url.pathname.includes('/search'), { timeout: 30_000 });\n28:     await page.waitForLoadState('domcontentloaded');\n29:     await simulateBodyClickToUnblock(page);\n30:     await page.locator('h1').first().waitFor({ state: 'visible', timeout: 30_000 });\n31: }\n32: \n33: // Capture a full-page screenshot only on failure\n34: test.afterEach(async ({ page }, testInfo) => {\n35:     await takeEvidenceScreenshot(page, testInfo);\n36: });\n37: \n38: // ---------------------------------------------------------------------------\n39: // TC-83235  PDP — Second-level breadcrumb link navigates back to category\n40: // ADO TC: 83235 | Priority: P1 | Type: Positive\n41: // ---------------------------------------------------------------------------\n42: test(\n43:     'TC-83235 — Second-level breadcrumb link on PDP navigates back to category listing @pdp @breadcrumbs @navigation',\n44:     async ({ page }) => {\n45:         const homePage = new HomePage(page);\n46:         const searchResultsPage = new SearchResultsPage(page);\n47:         const pdpPage = new ProductDetailPage(page);\n48: \n49:         await test.step('Navigate to a vitamins product detail page via search', async () => {\n50:             await navigateToVitaminsPdp(page, homePage, searchResultsPage);\n51:         });\n52: \n53:         let breadcrumbHref = '';\n54:         let breadcrumbText = '';\n55: \n56:         await test.step('Verify second-level breadcrumb link is visible', async () => {\n57:             await pdpPage.secondLevelBreadcrumb.waitFor({ state: 'visible', timeout: 30_000 });\n58:             breadcrumbText = (await pdpPage.secondLevelBreadcrumb.textContent() ?? '').trim();\n59:             breadcrumbHref = (await pdpPage.secondLevelBreadcrumb.getAttribute('href') ?? '').trim();\n60:             expect(breadcrumbText.length).toBeGreaterThan(0);\n61:             expect(breadcrumbHref).toMatch(/^\\/category\\//);\n62:         });\n63: \n64:         await test.step('Click second-level breadcrumb link', async () => {\n65:             await pdpPage.secondLevelBreadcrumb.click();\n66:         });\n67: \n68:         await test.step('Verify navigation lands on category listing page', async () => {\n69:             // The category URL follows the pattern /category/<slug>/c/<id>\n70:             await page.waitForURL(/\\/category\\//, { timeout: 30_000 });\n71:             await expect(page).toHaveURL(new RegExp(breadcrumbHref.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&')));\n72:             // The category page renders with a heading or product list — verify h1 or h2 is present\n73:             await page.locator('h1, h2').first().waitFor({ state: 'visible', timeout: 30_000 });\n74:         });\n75:     }\n76: );\n77: \n78: // ---------------------------------------------------------------------------\n79: // TC-83236  PDP — Price element is visible and formatted correctly\n80: // ADO TC: 83236 | Priority: P1 | Type: Positive"}}
