{"event": "tool_result", "tool": "view", "is_error": false, "result": {"status": "success", "file": "/Users/virginia.zambudio/PlaywrightAutomation/tests/pdp.spec.ts", "content": "245: \n246: // ---------------------------------------------------------------------------\n247: // TC-83240  PDP — Authenticated user clicks heart icon to add product to\n248: //           wishlist and API call confirms the action\n249: // ADO TC: 83240 | Priority: P1 | Type: Positive\n250: //\n251: // Precondition: Valid test account credentials are available.\n252: // Credentials are read from environment variables (see pdp.data.ts):\n253: //   TEST_USER_EMAIL / TEST_USER_PASSWORD\n254: // ---------------------------------------------------------------------------\n255: test(\n256:     'TC-83240 — Authenticated user adds product to wishlist and API call confirms the action @pdp @wishlist @authenticated',\n257:     async ({ page }) => {\n258:         const loginPage = new LoginPage(page);\n259:         const homePage = new HomePage(page);\n260:         const searchResultsPage = new SearchResultsPage(page);\n261:         const pdpPage = new ProductDetailPage(page);\n262: \n263:         // ── Precondition: Log in ────────────────────────────────────────────\n264:         await test.step('Log in with test user credentials', async () => {\n265:             await loginPage.login(pdpData.auth.email, pdpData.auth.password);\n266:         });\n267: \n268:         // ── Navigate to a vitamins PDP ──────────────────────────────────────\n269:         await test.step('Navigate to a vitamins product detail page via search', async () => {\n270:             await navigateToVitaminsPdp(page, homePage, searchResultsPage);\n271:         });\n272: \n273:         await test.step('Verify the wishlist heart button is visible', async () => {\n274:             await pdpPage.wishlistButton.waitFor({ state: 'visible', timeout: 30_000 });\n275:         });\n276: \n277:         // ── Intercept wishlist API call and click heart ─────────────────────\n278:         await test.step('Click the heart icon and confirm the wishlist API call is made', async () => {\n279:             // Set up a response promise BEFORE clicking so we don't miss fast responses.\n280:             // The UAT site uses Next.js server actions; wishlist operations POST to the\n281:             // current PDP URL with action payload, returning JSON with isSuccess: true.\n282:             // We wait for ANY POST to the current page URL that returns a 200 response.\n283:             const wishlistResponsePromise = page.waitForResponse(\n284:                 (response) =>\n285:                     response.request().method() === 'POST' &&\n286:                     response.url().includes('/products/') &&\n287:                     response.status() === 200,\n288:                 { timeout: 30_000 }\n289:             );\n290: \n291:             await pdpPage.wishlistButton.click();\n292: \n293:             // Wait for the API response confirming the wishlist action was processed\n294:             const response = await wishlistResponsePromise;\n295:             expect(response.status()).toBe(200);\n296: \n297:             // Optionally parse the response body to verify isSuccess: true\n298:             let body: string | null = null;\n299:             try {\n300:                 body = await response.text();\n301:             } catch {\n302:                 // Body may be binary or already consumed; skip body check\n303:             }\n304:             if (body && body.includes('isSuccess')) {\n305:                 expect(body).toMatch(/isSuccess.*true/i);\n306:             }\n307:         });\n308:     }\n309: );"}}
