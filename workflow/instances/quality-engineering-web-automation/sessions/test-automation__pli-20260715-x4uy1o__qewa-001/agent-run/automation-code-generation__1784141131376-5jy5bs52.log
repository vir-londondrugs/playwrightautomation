{"event": "tool_call", "tool": "edit", "args": {"file_path": "/Users/virginia.zambudio/PlaywrightAutomation/pages/ProductDetailPage.ts", "old_string": "    /**\n     * Opens the store selector dialog and waits for it to be visible.\n     *\n     * Two states are handled:\n     *   1. No store set yet  -- a \\\"Set your store\\\" link is visible.\n     *   2. Store already set -- the site (e.g. via geolocation on Firefox/WebKit)\n     *      pre-selects a store, replacing the \\\"Set your store\\\" link with\n     *      \\\"Check Availability at other stores\\\". Clicking that link also opens\n     *      the `dialog#store-selector` so the rest of the flow is identical.\n     *\n     * Scrolls to the fulfillment section first to ensure intersection-observer\n     * elements are mounted before waiting.\n     */\n    async openStoreSelectorDialog(): Promise<void> {\n        // Scroll the fulfillment area into view so lazy-rendered elements mount.\n        await this.inStorePickupRadio\n            .scrollIntoViewIfNeeded({ timeout: 10_000 })\n            .catch(() => undefined);\n\n        // Allow a moment for intersection-observer elements to mount after the\n        // scroll. Firefox and WebKit hydrate more slowly than Chromium, so use\n        // a 2.5 s wait to give the store-selector link time to appear.\n        await this.page.waitForTimeout(2_500);\n\n        const checkAvailabilityLink = this.page\n            .locator('p.cursor-pointer')\n            .filter({ hasText: /check availability at other stores/i })\n            .first();\n\n        // Try \"Set your store\" first (no store set). locator.isVisible() does NOT\n        // accept a timeout option -- it returns immediately. Use waitFor with a\n        // short timeout inside a try/catch so we genuinely wait up to 5 s before\n        // falling back to \"Check Availability at other stores\" (store already set).\n        let setStoreVisible = false;\n        try {\n            await this.setYourStoreLink.waitFor({ state: 'visible', timeout: 5_000 });\n            setStoreVisible = true;\n        } catch {\n            setStoreVisible = false;\n        }\n\n        if (setStoreVisible) {\n            await this.setYourStoreLink.click();\n        } else {\n            await checkAvailabilityLink.waitFor({ state: 'visible', timeout: 15_000 });\n            await checkAvailabilityLink.click();\n        }\n\n        await this.storeSelectorDialog.waitFor({ state: 'visible', timeout: 10_000 });\n    }", "new_string": "    /**\n     * Opens the store selector dialog and waits for it to be visible.\n     *\n     * Two states are handled:\n     *   1. No store set yet  -- a \"Set your store\" link is visible.\n     *   2. Store already set -- the site (e.g. via geolocation on Firefox/WebKit)\n     *      pre-selects a store, replacing the \"Set your store\" link with\n     *      \"Check Availability at other stores\". Clicking that link also opens\n     *      the `dialog#store-selector` so the rest of the flow is identical.\n     *\n     * Scrolls to the fulfillment section first to ensure intersection-observer\n     * elements are mounted before waiting.\n     *\n     * Firefox and WebKit note: `inStorePickupRadio` is not present on all products\n     * (some products only offer Ship to Home). We fall back to scrolling via the\n     * \"Set your store\" link itself or a fixed scroll amount so the fulfillment\n     * section is always brought into view regardless of radio availability.\n     */\n    async openStoreSelectorDialog(): Promise<void> {\n        // Attempt to scroll the In-Store Pickup radio into view; it may not exist\n        // on all products (e.g. Ship-to-Home-only items). Silently ignore failure.\n        await this.inStorePickupRadio\n            .scrollIntoViewIfNeeded({ timeout: 5_000 })\n            .catch(() => undefined);\n\n        // Fallback scroll: bring the \"Set your store\" link into view if it is\n        // already in the DOM (it often is before full hydration). Silently ignore.\n        await this.setYourStoreLink\n            .scrollIntoViewIfNeeded({ timeout: 5_000 })\n            .catch(() => undefined);\n\n        // Additional fixed scroll to ensure the fulfillment section (roughly\n        // 60-80 % down the page) is within the viewport. This triggers any\n        // remaining intersection observers in Firefox and WebKit.\n        await this.page.evaluate(() => {\n            window.scrollBy(0, Math.round(document.body.scrollHeight * 0.6));\n        });\n\n        // Allow intersection-observer elements to mount. Firefox and WebKit\n        // hydrate more slowly than Chromium — use 3 s to be safe.\n        await this.page.waitForTimeout(3_000);\n\n        const checkAvailabilityLink = this.page\n            .locator('p.cursor-pointer')\n            .filter({ hasText: /check availability at other stores/i })\n            .first();\n\n        // Try \"Set your store\" first (no store set yet). Use a 12 s window —\n        // Firefox and WebKit can take longer than Chromium to hydrate the\n        // fulfillment section.\n        let setStoreVisible = false;\n        try {\n            await this.setYourStoreLink.waitFor({ state: 'visible', timeout: 12_000 });\n            setStoreVisible = true;\n        } catch {\n            setStoreVisible = false;\n        }\n\n        if (setStoreVisible) {\n            await this.setYourStoreLink.click();\n        } else {\n            // Store was pre-selected by the browser (geolocation). Click the\n            // \"Check Availability at other stores\" link instead.\n            await checkAvailabilityLink.waitFor({ state: 'visible', timeout: 15_000 });\n            await checkAvailabilityLink.click();\n        }\n\n        await this.storeSelectorDialog.waitFor({ state: 'visible', timeout: 10_000 });\n    }"}}
