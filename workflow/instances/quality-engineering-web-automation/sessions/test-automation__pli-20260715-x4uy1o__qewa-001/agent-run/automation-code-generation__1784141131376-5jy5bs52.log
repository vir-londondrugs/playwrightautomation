Button.waitFor({ state: 'visible', timeout: 30_000 });\n337:             await homePage.megaMenuButton.click();\n338:         });\n339: \n340:         await test.step('Verify mega menu is visible', async () => {\n341:             await expect(homePage.megaMenu).toBeVisible({ timeout: 30_000 });\n342:         });\n343: \n344:         await test.step('Verify the hamburger button itself is still visible', async () => {\n345:             await expect(homePage.megaMenuButton).toBeVisible();\n346:         });\n347:     }\n348: );\n349: \n350: // ---------------------------------------------------------------------------\n351: // TC-83231  Home Page — Header nav links have correct hrefs\n352: // ADO TC: 83231 | Priority: P1 | Type: Positive\n353: // Hrefs confirmed from live UAT DOM inspection (header element scope).\n354: // ---------------------------------------------------------------------------\n355: test(\n356:     'TC-83231 — Main navigation links (Deals, Services, Flyers, Gift Registry) are visible and redirect to the correct pages @navigation @header',\n357:     async ({ page }) => {\n358:         const homePage = new HomePage(page);\n359:         const { headerNav } = homePageData;\n360: \n361:         await test.step('Navigate to homepage', async () => {\n362:             await homePage.navigate(homePageData.urls.home);\n363:         });\n364: \n365:         await test.step('Click page body to unblock loading overlay', async () => {\n366:             await page.locator('body').click({ force: true });\n367:         });\n368: \n369:         await test.step('Verify \"Deals & Events\" link is visible and has correct href', async () => {\n370:             await homePage.dealsLink.waitFor({ state: 'visible', timeout: 30_000 });\n371:             await expect(homePage.dealsLink).toHaveAttribute('href', headerNav.deals.href);\n372:         });\n373: \n374:         await test.step('Verify \"Services\" link is visible and has correct href', async () => {\n375:           