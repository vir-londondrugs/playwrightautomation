[14:19:55] {"event": "tool_result", "tool": "view", "is_error": false, "result": {"status": "success", "file": "/Users/virginia.zambudio/PlaywrightAutomation/helpers/page-load.ts", "content": "1: /**\n2:  * Page Load Strategy — Body-Click Unblocking\n3:  *\n4:  * The UAT London Drugs site (Next.js + Builder.io) sometimes gets stuck in a\n5:  * \"loading\" state where a blocking overlay or an infinite spinner prevents user\n6:  * interaction.  A synthetic body click reliably dismisses these overlays and\n7:  * triggers the site's client-side hydration to complete.\n8:  *\n9:  * Usage:\n10:  *\n11:  *   import { simulateBodyClickToUnblock } from '../helpers/page-load';\n12:  *\n13:  *   await homePage.navigate(url);\n14:  *   await simulateBodyClickToUnblock(page);\n15:  *\n16:  * This helper is intentionally thin — it wraps the pattern already used inside\n17:  * `BasePage.dismissLoadingIfStuck()` so that individual spec files can call it\n18:  * with a single descriptive name inside `test.step`.\n19:  */\n20: \n21: import { Page } from '@playwright/test';\n22: \n23: /**\n24:  * Simulates a body click to unblock page loading.\n25:  *\n26:  * After any navigation that may leave the page in a partially hydrated state,\n27:  * call this helper to force-click the body element.  This action:\n28:  *   1. Dismisses blocking overlays (cookie banners, permission prompts, etc.).\n29:  *   2. Triggers React / Builder.io hydration if it stalled on the first render.\n30:  *   3. Unlocks lazy-initialised event listeners that only attach after a click.\n31:  *\n32:  * The click uses `force: true` so it succeeds even when an overlay covers the\n33:  * body and Playwright would otherwise refuse to click an obscured element.\n34:  *\n35:  * The 500ms wait after the click is intentional — it allows the Next.js / Builder.io\n36:  * hydration cycle to complete before the next interaction. This is NOT a reliability\n37:  * wait; it is the documented pattern from DISCOVERY-SPEC (Journey A step 2).\n38:  */\n39: export async function simulateBodyClickToUnblock(page: Page): Promise<void> {\n40:     await page.locator('body').click({ force: true });\n41:     await page.waitForTimeout(500);\n42: }"}}
