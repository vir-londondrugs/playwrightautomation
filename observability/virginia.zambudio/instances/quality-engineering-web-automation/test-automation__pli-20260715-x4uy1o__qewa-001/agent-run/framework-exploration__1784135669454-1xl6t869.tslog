[14:19:58] {"event": "tool_result", "tool": "view", "is_error": false, "result": {"status": "success", "file": "/Users/virginia.zambudio/PlaywrightAutomation/helpers/apiInterceptor.ts", "content": "1: import { Page, Request, Route } from '@playwright/test';\n2: \n3: /** URL pattern for the UAT search API (filter/sort results). */\n4: const SEARCH_API_PATTERN = '**/api/search*';\n5: \n6: /** Production hostname that sort may redirect to (OQ-01). */\n7: const PRODUCTION_HOST = 'www.londondrugs.com';\n8: \n9: /**\n10:  * Sets up a one-time route handler that intercepts the first outgoing request\n11:  * matching the search API pattern. The intercepted request is resolved via the\n12:  * returned promise, allowing callers to assert on its URL or POST body after\n13:  * the filter/sort action fires.\n14:  *\n15:  * Usage (FTC_02_01_01):\n16:  *   const requestPromise = interceptSearchApi(page);\n17:  *   await searchResultsPage.applyFilters();\n18:  *   const req = await requestPromise;\n19:  *   expect(req.url()).toContain('facet=');\n20:  *\n21:  * @param page - Active Playwright Page.\n22:  * @returns Promise that resolves with the first intercepted search API Request.\n23:  */\n24: export function interceptSearchApi(page: Page): Promise<Request> {\n25:     return new Promise((resolve) => {\n26:         page.route(SEARCH_API_PATTERN, async (route: Route, request: Request) => {\n27:             // Resolve the promise with the intercepted request for assertions.\n28:             resolve(request);\n29:             // Continue the request so the page receives its response.\n30:             await route.continue();\n31:             // Unregister after first match to avoid intercepting subsequent calls.\n32:             await page.unroute(SEARCH_API_PATTERN);\n33:         });\n34:     });\n35: }\n36: \n37: /**\n38:  * Waits for the page to make a search API call after a filter or sort action.\n39:  * Simpler alternative to interceptSearchApi when only network activity needs\n40:  * to be confirmed (not request payload inspection).\n41:  *\n42:  * Usage (FTC_02_01_01 simple variant):\n43:  *   await waitForFilterApiCall(page);\n44:  *\n45:  * @param page - Active Playwright Page.\n46:  * @param timeoutMs - Maximum ms to wait. Default 15 000 ms.\n47:  */\n48: export async function waitForFilterApiCall(\n49:     page: Page,\n50:     timeoutMs: number = 15_000,\n51: ): Promise<void> {\n52:     await page.waitForRequest(\n53:         (req) => req.url().includes('/api/search') || req.url().includes('/graphql'),\n54:         { timeout: timeoutMs },\n55:     );\n56: }\n57: \n58: /**\n59:  * Intercepts any navigation to the production domain that may be triggered by\n60:  * a sort or filter action on UAT (OQ-01). When the browser tries to navigate to\n61:  * www.londondrugs.com, this handler aborts the cross-domain redirect and lets\n62:  * the UAT response proceed instead.\n63:  *\n64:  * MCP-validated 2026-07-13: both sort AND filter apply actions on UAT redirect to\n65:  * www.londondrugs.com. This interceptor must be called before either action.\n66:  *\n67:  * Call BEFORE triggering the sort/filter action. This is registered as a persistent\n68:  * route (not one-time) so callers must call page.unroute() when done, or\n69:  * rely on page teardown.\n70:  *\n71:  * Usage (FTC_02_02_01 sort, FTC_02_01_01 filter):\n72:  *   await interceptAndAbortSortRedirect(page);\n73:  *   // ...trigger sort or filter...\n74:  *   // Assert URL on UAT; production redirect has been aborted.\n75:  *\n76:  * @param page - Active Playwright Page.\n77:  */\n78: export async function interceptAndAbortSortRedirect(page: Page): Promise<void> {\n79:     await page.route(`**${PRODUCTION_HOST}**`, async (route: Route) => {\n80:         const url = route.request().url();\n81:         if (url.includes(PRODUCTION_HOST)) {\n82:             // Abort cross-domain redirect; keep test on UAT origin.\n83:             await route.abort('blockedbyclient');\n84:         } else {\n85:             await route.continue();\n86:         }\n87:     });\n88: }\n89: \n90: /**\n91:  * Alias for interceptAndAbortSortRedirect -- covers filter-apply redirects too.\n92:  * MCP-validated 2026-07-13: filter apply on UAT also redirects to www.londondrugs.com.\n93:  *\n94:  * @param page - Active Playwright Page.\n95:  */\n96: export const interceptAndAbortFilterRedirect = interceptAndAbortSortRedirect;"}}
