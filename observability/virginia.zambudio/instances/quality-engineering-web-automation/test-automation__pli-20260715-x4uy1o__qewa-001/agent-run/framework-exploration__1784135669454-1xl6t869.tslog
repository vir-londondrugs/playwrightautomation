[14:15:49] {"event": "tool_result", "tool": "view", "is_error": false, "result": {"status": "success", "file": "/Users/virginia.zambudio/PlaywrightAutomation/tests/home-page.spec.ts", "content": "395: //   /enewsletter-settings?email=<encoded_email>\n396: // No confirmation message is shown on the homepage itself.\n397: // Verification: URL matches /enewsletter-settings after submit.\n398: // ---------------------------------------------------------------------------\n399: test(\n400:     'TC-83232 — Newsletter signup in footer accepts valid email and redirects to confirmation @newsletter @footer',\n401:     async ({ page }) => {\n402:         // Override the global 60 s timeout: Builder.io networkidle can take 30 s,\n403:         // plus the retry loop (~15 s) and the final waitFor (45 s). 180 s is safe.\n404:         test.setTimeout(180_000);\n405: \n406:         const homePage = new HomePage(page);\n407:         const { newsletter } = homePageData;\n408: \n409:         await test.step('Navigate to homepage', async () => {\n410:             await homePage.navigate(homePageData.urls.home);\n411:         });\n412: \n413:         await test.step('Scroll to footer newsletter form', async () => {\n414:             // The newsletter section is Builder.io-driven: it is rendered as a\n415:             // direct child of <body> and requires both the page to be fully hydrated\n416:             // and a scroll-to-bottom to trigger intersection observers that mount it.\n417:             // Strategy:\n418:             //   1. Scroll window to the very bottom to trigger the observer.\n419:             //   2. Wait for network to settle so Builder.io lazy content can load.\n420:             //      Use a 30 s timeout (UAT is slow; 10 s was too short on CI).\n421:             //   3. Attempt scrollIntoViewIfNeeded on the locator itself (Playwright\n422:             //      forces the browser to bring the element into the viewport, which\n423:             //      re-triggers any intersection observer if the element exists in DOM).\n424:             //   4. Poll isVisible() in a retry loop with repeated scroll triggers for\n425:             //      up to ~15 s before the final waitFor.\n426:             await page.evaluate(() => window.scrollTo(0, document.body.scrollHeight));\n427:             // Allow additional time for Builder.io content to be fetched and rendered.\n428:             await page.waitForLoadState('networkidle', { timeout: 30_000 }).catch(() => {});\n429:             await page.waitForTimeout(1_000);\n430: \n431:             // Repeat scroll to bottom in case the page grew after Builder.io rendered.\n432:             await page.evaluate(() => window.scrollTo(0, document.body.scrollHeight));\n433:             await page.waitForTimeout(500);\n434: \n435:             // scrollIntoViewIfNeeded triggers intersection observers on elements\n436:             // already in the DOM but outside the viewport.\n437:             await homePage.newsletterEmailInput\n438:                 .scrollIntoViewIfNeeded({ timeout: 5_000 })\n439:                 .catch(() => undefined);\n440: \n441:             // Poll for visibility in a retry loop as a belt-and-suspenders guard.\n442:             // Increased retries and interval to handle slow UAT / CI environments.\n443:             for (let scrollAttempt = 0; scrollAttempt < 15; scrollAttempt++) {\n444:                 const inputVisible = await homePage.newsletterEmailInput\n445:                     .isVisible()\n446:                     .catch(() => false);\n447:                 if (inputVisible) break;\n448:                 await page.evaluate(() => window.scrollTo(0, document.body.scrollHeight));\n449:                 await page.waitForTimeout(1_000);\n450:             }\n451: \n452:             await homePage.newsletterEmailInput.waitFor({ state: 'visible', timeout: 45_000 });\n453:         });\n454: \n455:         await test.step('Fill valid email in newsletter input', async () => {\n456:             await homePage.newsletterEmailInput.fill(newsletter.testEmail);\n457:         });\n458: \n459:         await test.step('Click SIGN UP button', async () => {\n460:             await homePage.newsletterSubmitButton.waitFor({ state: 'visible', timeout: 30_000 });\n461:             // The newsletter section can have an overlapping layout element on some browsers\n462:             // (e.g. Edge). Use force:true to bypass the actionability overlay check and\n463:             // dispatch the click event directly to the button element.\n464:             await homePage.newsletterSubmitButton.click({ force: true });\n465:         });\n466: \n467:         await test.step('Verify page redirects to /enewsletter-settings', async () => {\n468:             // Submit triggers a client-side navigation to /enewsletter-settings?email=<email>.\n469:             // This confirms the form was accepted and the user is routed to the preferences page.\n470:             await page.waitForURL(newsletter.expectedRedirectUrlPattern, { timeout: 45_000 });\n471:             await expect(page).toHaveURL(newsletter.expectedRedirectUrlPattern);\n472:         });\n473:     }\n474: );"}}
