[14:19:48] {"event": "tool_result", "tool": "view", "is_error": false, "result": {"status": "success", "file": "/Users/virginia.zambudio/PlaywrightAutomation/tests/home-page.spec.ts", "content": "1: import { test, expect } from '@playwright/test';\n2: import { HomePage } from '../pages/HomePage';\n3: import { SearchResultsPage } from '../pages/SearchResultsPage';\n4: import { StoreLocatorPage } from '../pages/StoreLocatorPage';\n5: import { homePageData } from '../test-data/home-page.data';\n6: import { takeEvidenceScreenshot } from '../helpers/evidence';\n7: \n8: // Capture a full-page screenshot only on failure and save it to artifacts/outputs/\n9: test.afterEach(async ({ page }, testInfo) => {\n10:     await takeEvidenceScreenshot(page, testInfo);\n11: });\n12: \n13: // ---------------------------------------------------------------------------\n14: // TC-83225  Home Page — Logo Click navigates to Home\n15: // ADO TC: 83225 | Priority: P1 | Type: Positive\n16: // ---------------------------------------------------------------------------\n17: test(\n18:     'TC-83225 — Logo click navigates to home @homepage @navigation @smoke',\n19:     async ({ page }) => {\n20:         const homePage = new HomePage(page);\n21: \n22:         await test.step('Navigate to an internal page (not home)', async () => {\n23:             await homePage.navigate(homePageData.urls.home);\n24:         });\n25: \n26:         await test.step('Click page body to unblock loading after search', async () => {\n27:             await page.locator('body').click({ force: true });\n28:         });\n29: \n30:         await test.step('Click the London Drugs logo', async () => {\n31:             await homePage.clickLogo();\n32:         });\n33: \n34:         await test.step('Click page body to dismiss loading overlay if stuck', async () => {\n35:             await homePage.dismissLoadingIfStuck();\n36:         });\n37: \n38:         await test.step('Verify home page is loaded after logo click', async () => {\n39:             await page.waitForURL(homePageData.logo.expectedHomeUrlGlob);\n40:             await expect(page).toHaveURL(homePageData.logo.expectedHomeUrlRegex);\n41:             await expect(page).toHaveTitle(homePageData.logo.expectedTitle);\n42:             await expect(homePage.logo).toBeVisible();\n43:         });\n44:     }\n45: );\n46: \n47: // ---------------------------------------------------------------------------\n48: // TC-83226  Home Page — Search with no results shows 'Nothing found'\n49: // ADO TC: 83226 | Priority: P1 | Type: Negative\n50: // ---------------------------------------------------------------------------"}}
