[14:15:43] {"event": "tool_result", "tool": "view", "is_error": false, "result": {"status": "success", "file": "/Users/virginia.zambudio/PlaywrightAutomation/pages/HomePage.ts", "content": "1: import { Page, Locator } from '@playwright/test';\n2: import { BasePage } from './BasePage';\n3: \n4: export class HomePage extends BasePage {\n5:     /** The London Drugs logo image inside the home anchor link */\n6:     readonly logo: Locator;\n7: \n8:     /** The global site search input field */\n9:     readonly searchInput: Locator;\n10: \n11:     /** Header link to the Store Locator page */\n12:     readonly storesLink: Locator;\n13: \n14:     /** Mini cart icon button in the header */\n15:     readonly miniCartButton: Locator;\n16: \n17:     /** Mini cart slide-out panel that appears after clicking the cart icon */\n18:     readonly miniCartPanel: Locator;\n19: \n20:     /** \"View Cart\" button/link inside the mini cart panel (UAT label) */\n21:     readonly proceedToCheckoutButton: Locator;\n22: \n23:     /** Hamburger / mega menu toggle button in the header */\n24:     readonly megaMenuButton: Locator;\n25: \n26:     /** Mega menu container that opens after clicking the hamburger button */\n27:     readonly megaMenu: Locator;\n28: \n29:     // -- Header navigation links (TC-83231) ----------------------------------\n30: \n31:     /** \"Deals & Events\" link in the top header nav */\n32:     readonly dealsLink: Locator;\n33: \n34:     /** \"Services\" link in the top header nav */\n35:     readonly servicesLink: Locator;\n36: \n37:     /** \"Flyers\" link in the top header nav */\n38:     readonly flyersLink: Locator;\n39: \n40:     /** \"Gift Registry\" link in the top header nav */\n41:     readonly giftRegistryLink: Locator;\n42: \n43:     // -- Footer newsletter signup (TC-83232) ---------------------------------\n44: \n45:     /** Email input in the footer newsletter signup form */\n46:     readonly newsletterEmailInput: Locator;\n47: \n48:     /** Submit button (\"SIGN UP\") in the footer newsletter signup form */\n49:     readonly newsletterSubmitButton: Locator;\n50: \n51:     constructor(page: Page) {\n52:         super(page);\n53:         this.logo = page.locator('a[href=\"/\"] img[alt=\"London Drugs\"]').first();\n54:         this.searchInput = page.getByPlaceholder('Find your product').first();\n55:         this.storesLink = page.locator('a[href=\"/stores\"]').first();\n56:         this.miniCartButton = page.locator('button[aria-label=\"Show Mini Cart Items\"]').first();\n57:         // Mini-cart panel: confirmed on UAT as an absolute z-50 div with min-w-80.\n58:         // Always present in DOM regardless of cart state; using min-w-80 makes the selector\n59:         // unique to this panel (no other z-50 element has min-w-80 on the page).\n60:         this.miniCartPanel = page.locator('div[class*=\"z-50\"][class*=\"min-w-80\"]').first();\n61:         // Checkout CTA inside the mini-cart panel: UAT shows \"View Cart\" (not \"Proceed to Checkout\").\n62:         // button.primary-button.w-full confirmed on live UAT DOM inspection.\n63:         this.proceedToCheckoutButton = page.locator('button.primary-button.w-full').filter({ hasText: 'View Cart' }).first();\n64:         // Mega-menu button: three are in the DOM for responsive breakpoints; :visible picks the rendered one.\n65:         this.megaMenuButton = page.locator('button[aria-label=\"Opens Mega Menu\"]:visible').first();\n66:         // Mega-menu container: confirmed on UAT as a <div> with class containing \"bg-txtmegamenu-secondary\".\n67:         // There are two such divs: the first is the mobile drawer (lg:hidden), the second is the\n68:         // persistent desktop nav (lg:flex). Using .last() targets the always-visible desktop nav\n69:         // that becomes the verified \"mega menu is open\" state at Desktop Chrome viewport.\n70:         this.megaMenu = page.locator('div[class*=\"bg-txtmegamenu-secondary\"]').last();\n71: \n72:         // Header nav links -- confirmed hrefs from live UAT DOM inspection.\n73:         this.dealsLink = page.locator('header a[href=\"/category/deals-and-events/c/1027\"]').first();\n74:         this.servicesLink = page.locator('header a[href=\"/our-services\"]').first();\n75:         this.flyersLink = page.locator('header a[href=\"/flyer\"]').first();\n76:         this.giftRegistryLink = page.locator('header a[href=\"/myaccount/wishlist#registry\"]').first();\n77: \n78:         // Newsletter signup section -- confirmed from live UAT DOM inspection (2026-07-08).\n79:         // The section is a <div class=\"...bg-primary...\"> directly under <body> (NOT inside\n80:         // <footer>). The email input has placeholder \"Enter your email\" and type=\"email\".\n81:         // The button text is \"SIGN UP\".\n82:         // The section is present in the DOM on page load but requires scrolling to become\n83:         // visible (intersection-observer driven rendering).\n84:         this.newsletterEmailInput = page.locator('div.bg-primary input[type=\"email\"]').first();\n85:         this.newsletterSubmitButton = page.locator('div.bg-primary button[type=\"submit\"]').filter({ hasText: /sign up/i }).first();\n86:     }\n87: \n88:     async clickLogo(): Promise<void> {\n89:         await this.logo.waitFor({ state: 'visible' });\n90:         await this.logo.click();\n91:     }\n92: \n93:     /**\n94:      * Waits for the search input to be visible and enabled (React hydration complete).\n95:      * Call this after navigate() before interacting with the search input.\n96:      */\n97:     async waitForSearchInput(): Promise<void> {\n98:         await this.searchInput.waitFor({ state: 'visible', timeout: 60_000 });\n99:         await this.page.waitForFunction(\n100:             () => {\n101:                 const input = document.querySelector<HTMLInputElement>('input[placeholder=\"Find your product\"]');\n102:                 return input !== null && !input.disabled;\n103:             },\n104:             { timeout: 30_000 }\n105:         );\n106:     }\n107: \n108:     async search(term: string): Promise<void> {\n109:         await this.searchInput.click();\n110:         await this.searchInput.fill(term);\n111:         await this.searchInput.press('Enter');\n112:     }\n113: }"}}
