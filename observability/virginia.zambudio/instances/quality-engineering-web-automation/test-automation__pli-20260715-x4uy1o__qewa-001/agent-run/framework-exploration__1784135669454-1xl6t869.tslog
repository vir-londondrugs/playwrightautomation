[14:19:33] {"event": "tool_result", "tool": "view", "is_error": false, "result": {"status": "success", "file": "/Users/virginia.zambudio/PlaywrightAutomation/helpers/evidence.ts", "content": "1: import * as fs from 'fs';\n2: import * as path from 'path';\n3: import { Page, TestInfo } from '@playwright/test';\n4: \n5: const EVIDENCE_DIR = path.resolve(__dirname, '../artifacts/outputs');\n6: \n7: /**\n8:  * Takes a screenshot and saves it as evidence for the current TC.\n9:  * Screenshot is only captured when the test has FAILED.\n10:  *\n11:  * Filename format: {TC-number}_{YYYY-MM-DD_HH-mm-ss}.png\n12:  * Example: TC-79593-02-negative_2026-06-23_14-30-05.png\n13:  *\n14:  * The TC number is extracted from the test title (e.g. \"TC-79593-02-negative — …\").\n15:  * If no TC number is found the sanitized test title is used as fallback.\n16:  */\n17: export async function takeEvidenceScreenshot(page: Page, testInfo: TestInfo): Promise<void> {\n18:     if (testInfo.status !== 'failed') return;\n19: \n20:     fs.mkdirSync(EVIDENCE_DIR, { recursive: true });\n21: \n22:     const tcMatch = testInfo.title.match(/TC-[\\w-]+/);\n23:     const tcId = tcMatch ? tcMatch[0] : testInfo.title.replace(/[^a-zA-Z0-9-_]/g, '_').slice(0, 60);\n24: \n25:     const now = new Date();\n26:     const timestamp = [\n27:         now.getFullYear(),\n28:         String(now.getMonth() + 1).padStart(2, '0'),\n29:         String(now.getDate()).padStart(2, '0'),\n30:     ].join('-') + '_' + [\n31:         String(now.getHours()).padStart(2, '0'),\n32:         String(now.getMinutes()).padStart(2, '0'),\n33:         String(now.getSeconds()).padStart(2, '0'),\n34:     ].join('-');\n35: \n36:     const filename = `${tcId}_${timestamp}.png`;\n37:     const filepath = path.join(EVIDENCE_DIR, filename);\n38: \n39:     try {\n40:         await page.screenshot({ path: filepath, fullPage: true });\n41:     } catch (screenshotError) {\n42:         // Playwright can raise \"file data stream has unexpected number of bytes\"\n43:         // when the page is in an unstable state (navigation, overlay, test failure).\n44:         // Swallow the error so the real test failure is not masked.\n45:         console.warn(`[evidence] Screenshot failed for ${tcId}: ${screenshotError}`);\n46:     }\n47: }"}}
