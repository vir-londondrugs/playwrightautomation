{"event": "tool_result", "tool": "view", "is_error": false, "result": {"status": "success", "file": "/Users/virginia.zambudio/PlaywrightAutomation/pages/BasePage.ts", "content": "1: import { Page } from '@playwright/test';\n2: \n3: /** Timeout (ms) to wait for the page to reach 'load' state before clicking to dismiss loaders */\n4: const LOAD_STATE_TIMEOUT_MS = 15_000;\n5: \n6: /**\n7:  * Timeout (ms) to wait for the site's React/Next.js app shell (header) to hydrate.\n8:  * On the UAT origin the SPA may finish 'load' before the header is interactive.\n9:  */\n10: const HYDRATION_TIMEOUT_MS = 20_000;\n11: \n12: export class BasePage {\n13:     protected readonly page: Page;\n14: \n15:     constructor(page: Page) {\n16:         this.page = page;\n17:     }\n18: \n19:     async navigate(url: string): Promise<void> {\n20:         await this.page.goto(url);\n21:         await this.page.waitForLoadState('domcontentloaded');\n22:         await this.dismissLoadingIfStuck();\n23:         // After 'load', the Next.js app may still be hydrating (React errors are\n24:         // hydration mismatches that leave a loading spinner visible).\n25:         // Wait for the site header to appear as a signal that hydration completed.\n26:         await this.waitForAppShell();\n27:     }\n28: \n29:     /**\n30:      * Waits for the page to fully load. If it stays stuck in a loading state\n31:      * beyond the threshold, clicks the page body to dismiss overlays/spinners\n32:      * and gives the page another chance to finish loading.\n33:      */\n34:     async dismissLoadingIfStuck(): Promise<void> {\n35:         try {\n36:             await this.page.waitForLoadState('load', { timeout: LOAD_STATE_TIMEOUT_MS });\n37:         } catch {\n38:             // Page did not reach 'load' state in time: click body to dismiss\n39:             // any blocking overlay or infinite spinner and wait once more\n40:             await this.page.locator('body').click({ force: true });\n41:             await this.page.waitForLoadState('domcontentloaded');\n42:         }\n43:     }\n44: \n45:     /**\n46:      * Waits for the site's app shell (header element) to become visible,\n47:      * confirming that the Next.js/React SPA has hydrated past the loading state.\n48:      * Silently continues if the header does not appear within the timeout -- some\n49:      * pages (e.g. login redirect) may render without a standard header.\n50:      */\n51:     async waitForAppShell(): Promise<void> {\n52:         try {\n53:             await this.page.locator('header').first().waitFor({\n54:                 state: 'visible',\n55:                 timeout: HYDRATION_TIMEOUT_MS,\n56:             });\n57:         } catch {\n58:             // Header did not appear -- page may be mid-redirect or a login page.\n59:             // Click body to unblock any remaining hydration overlay and continue.\n60:             await this.page.locator('body').click({ force: true }).catch(() => undefined);\n61:         }\n62:     }\n63: }"}}
