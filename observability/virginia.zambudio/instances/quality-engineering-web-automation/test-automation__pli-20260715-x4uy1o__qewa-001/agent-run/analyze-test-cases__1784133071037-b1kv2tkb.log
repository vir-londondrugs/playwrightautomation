{"event": "tool_result", "tool": "view", "is_error": false, "result": {"status": "success", "file": "/Users/virginia.zambudio/PlaywrightAutomation/tests/home-page.spec.ts", "content": "390: \n391: // ---------------------------------------------------------------------------\n392: // TC-83232  Home Page — Newsletter signup in footer submits and redirects\n393: // ADO TC: 83232 | Priority: P1 | Type: Positive\n394: // The SIGN UP button submits via client-side navigation to:\n395: //   /enewsletter-settings?email=<encoded_email>\n396: // No confirmation message is shown on the homepage itself.\n397: // Verification: URL matches /enewsletter-settings after submit.\n398: // ---------------------------------------------------------------------------\n399: test(\n400:     'TC-83232 — Newsletter signup in footer accepts valid email and redirects to confirmation @newsletter @footer',\n401:     async ({ page }) => {\n402:         const homePage = new HomePage(page);\n403:         const { newsletter } = homePageData;\n404: \n405:         await test.step('Navigate to homepage', async () => {\n406:             await homePage.navigate(homePageData.urls.home);\n407:         });\n408: \n409:         await test.step('Scroll to footer newsletter form', async () => {\n410:             // The newsletter section is intersection-observer driven: it does not\n411:             // mount in the DOM until the viewport has scrolled near the bottom.\n412:             // Strategy:\n413:             //   1. Scroll window to the very bottom to trigger the observer.\n414:             //   2. Wait for network to settle so Builder.io lazy content can load.\n415:             //   3. Attempt scrollIntoViewIfNeeded on the locator itself (Playwright\n416:             //      forces the browser to bring the element into the viewport, which\n417:             //      re-triggers any intersection observer if the element exists in DOM).\n418:             //   4. Poll isVisible() in a retry loop for up to ~15 s before the\n419:             //      final waitFor which provides the clear timeout error message.\n420:             await page.evaluate(() => window.scrollTo(0, document.body.scrollHeight));\n421:             await page.waitForLoadState('networkidle', { timeout: 10_000 }).catch(() => {});\n422:             await page.waitForTimeout(500);\n423: \n424:             // scrollIntoViewIfNeeded triggers intersection observers on elements\n425:             // already in the DOM but outside the viewport.\n426:             await homePage.newsletterEmailInput\n427:                 .scrollIntoViewIfNeeded({ timeout: 5_000 })\n428:                 .catch(() => undefined);\n429: \n430:             // Poll for visibility in a retry loop as a belt-and-suspenders guard.\n431:             for (let scrollAttempt = 0; scrollAttempt < 8; scrollAttempt++) {\n432:                 const inputVisible = await homePage.newsletterEmailInput\n433:                     .isVisible()\n434:                     .catch(() => false);\n435:                 if (inputVisible) break;\n436:                 await page.evaluate(() => window.scrollTo(0, document.body.scrollHeight));\n437:                 await page.waitForTimeout(800);\n438:             }\n439: \n440:             await homePage.newsletterEmailInput.waitFor({ state: 'visible', timeout: 30_000 });\n441:         });\n442: \n443:         await test.step('Fill valid email in newsletter input', async () => {\n444:             await homePage.newsletterEmailInput.fill(newsletter.testEmail);\n445:         });\n446: \n447:         await test.step('Click SIGN UP button', async () => {\n448:             await homePage.newsletterSubmitButton.waitFor({ state: 'visible', timeout: 30_000 });\n449:             await homePage.newsletterSubmitButton.click();\n450:         });\n451: \n452:         await test.step('Verify page redirects to /enewsletter-settings', async () => {\n453:             // Submit triggers a client-side navigation to /enewsletter-settings?email=<email>.\n454:             // This confirms the form was accepted and the user is routed to the preferences page.\n455:             await page.waitForURL(newsletter.expectedRedirectUrlPattern, { timeout: 45_000 });\n456:             await expect(page).toHaveURL(newsletter.expectedRedirectUrlPattern);\n457:         });\n458:     }\n459: );"}}
