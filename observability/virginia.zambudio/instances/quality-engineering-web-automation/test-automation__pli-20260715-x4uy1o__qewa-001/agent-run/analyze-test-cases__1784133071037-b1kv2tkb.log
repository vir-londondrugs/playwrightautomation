{"event": "tool_call", "tool": "edit", "args": {"file_path": "/Users/virginia.zambudio/PlaywrightAutomation/tests/home-page.spec.ts", "old_string": "        await test.step('Scroll to footer newsletter form', async () => {\n            // The newsletter section is intersection-observer driven: it does not\n            // mount in the DOM until the viewport has scrolled near the bottom.\n            // Strategy:\n            //   1. Scroll window to the very bottom to trigger the observer.\n            //   2. Wait for network to settle so Builder.io lazy content can load.\n            //   3. Attempt scrollIntoViewIfNeeded on the locator itself (Playwright\n            //      forces the browser to bring the element into the viewport, which\n            //      re-triggers any intersection observer if the element exists in DOM).\n            //   4. Poll isVisible() in a retry loop for up to ~15 s before the\n            //      final waitFor which provides the clear timeout error message.\n            await page.evaluate(() => window.scrollTo(0, document.body.scrollHeight));\n            await page.waitForLoadState('networkidle', { timeout: 10_000 }).catch(() => {});\n            await page.waitForTimeout(500);\n\n            // scrollIntoViewIfNeeded triggers intersection observers on elements\n            // already in the DOM but outside the viewport.\n            await homePage.newsletterEmailInput\n                .scrollIntoViewIfNeeded({ timeout: 5_000 })\n                .catch(() => undefined);\n\n            // Poll for visibility in a retry loop as a belt-and-suspenders guard.\n            for (let scrollAttempt = 0; scrollAttempt < 8; scrollAttempt++) {\n                const inputVisible = await homePage.newsletterEmailInput\n                    .isVisible()\n                    .catch(() => false);\n                if (inputVisible) break;\n                await page.evaluate(() => window.scrollTo(0, document.body.scrollHeight));\n                await page.waitForTimeout(800);\n            }\n\n            await homePage.newsletterEmailInput.waitFor({ state: 'visible', timeout: 30_000 });\n        });", "new_string": "        await test.step('Scroll to footer newsletter form', async () => {\n            // The newsletter section is Builder.io-driven: it is rendered as a\n            // direct child of <body> and requires both the page to be fully hydrated\n            // and a scroll-to-bottom to trigger intersection observers that mount it.\n            // Strategy:\n            //   1. Scroll window to the very bottom to trigger the observer.\n            //   2. Wait for network to settle so Builder.io lazy content can load.\n            //      Use a 30 s timeout (UAT is slow; 10 s was too short on CI).\n            //   3. Attempt scrollIntoViewIfNeeded on the locator itself (Playwright\n            //      forces the browser to bring the element into the viewport, which\n            //      re-triggers any intersection observer if the element exists in DOM).\n            //   4. Poll isVisible() in a retry loop with repeated scroll triggers for\n            //      up to ~15 s before the final waitFor.\n            await page.evaluate(() => window.scrollTo(0, document.body.scrollHeight));\n            // Allow additional time for Builder.io content to be fetched and rendered.\n            await page.waitForLoadState('networkidle', { timeout: 30_000 }).catch(() => {});\n            await page.waitForTimeout(1_000);\n\n            // Repeat scroll to bottom in case the page grew after Builder.io rendered.\n            await page.evaluate(() => window.scrollTo(0, document.body.scrollHeight));\n            await page.waitForTimeout(500);\n\n            // scrollIntoViewIfNeeded triggers intersection observers on elements\n            // already in the DOM but outside the viewport.\n            await homePage.newsletterEmailInput\n                .scrollIntoViewIfNeeded({ timeout: 5_000 })\n                .catch(() => undefined);\n\n            // Poll for visibility in a retry loop as a belt-and-suspenders guard.\n            // Increased retries and interval to handle slow UAT / CI environments.\n            for (let scrollAttempt = 0; scrollAttempt < 15; scrollAttempt++) {\n                const inputVisible = await homePage.newsletterEmailInput\n                    .isVisible()\n                    .catch(() => false);\n                if (inputVisible) break;\n                await page.evaluate(() => window.scrollTo(0, document.body.scrollHeight));\n                await page.waitForTimeout(1_000);\n            }\n\n            await homePage.newsletterEmailInput.waitFor({ state: 'visible', timeout: 45_000 });\n        });"}}
