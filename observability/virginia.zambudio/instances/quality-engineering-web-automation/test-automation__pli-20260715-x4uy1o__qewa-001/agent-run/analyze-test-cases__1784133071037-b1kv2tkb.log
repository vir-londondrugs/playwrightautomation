{"event": "tool_result", "tool": "view", "is_error": false, "result": {"status": "success", "file": "/Users/virginia.zambudio/PlaywrightAutomation/pages/LoginPage.ts", "content": "1: import { Page, Locator } from '@playwright/test';\n2: import { BasePage } from './BasePage';\n3: \n4: export class LoginPage extends BasePage {\n5:     /** Email address input on the login form */\n6:     readonly emailInput: Locator;\n7: \n8:     /** Password input on the login form */\n9:     readonly passwordInput: Locator;\n10: \n11:     /** Login / Sign In submit button */\n12:     readonly loginButton: Locator;\n13: \n14:     constructor(page: Page) {\n15:         super(page);\n16:         this.emailInput = page.locator('input[name=\"email\"][type=\"email\"]').first();\n17:         this.passwordInput = page.locator('input[name=\"password\"][type=\"password\"]').first();\n18:         this.loginButton = page.locator('button[type=\"submit\"]').filter({ hasText: /login/i }).first();\n19:     }\n20: \n21:     /**\n22:      * Navigates to the My Account page (which redirects to the login form when\n23:      * the user is not authenticated) and logs in with the provided credentials.\n24:      * Waits for the URL to leave /myaccount/login as confirmation of success.\n25:      *\n26:      * Uses a 45s timeout for the email input because the UAT origin can be slow\n27:      * to hydrate the React form after the redirect, leaving only a loading spinner\n28:      * visible for the first 15-25 s.\n29:      */\n30:     async login(email: string, password: string): Promise<void> {\n31:         // Navigate directly via page.goto so we can control the URL-settle wait\n32:         // independently of the app-shell check (login page may not have a header).\n33:         await this.page.goto('/myaccount');\n34:         await this.page.waitForLoadState('domcontentloaded');\n35: \n36:         // /myaccount redirects to /myaccount/login. Wait for the redirect to settle\n37:         // before waiting for the form elements to mount.\n38:         await this.page.waitForURL(/login/, { timeout: 20_000 }).catch(() => {\n39:             // If the URL does not include \"login\" within 20 s the user may already\n40:             // be authenticated. Proceed and let the form-wait below time out naturally\n41:             // if the form is genuinely absent.\n42:         });\n43: \n44:         // The React login form can take up to 30-40 s to mount on UAT after the\n45:         // redirect resolves due to server-side rendering and hydration delays.\n46:         await this.emailInput.waitFor({ state: 'visible', timeout: 45_000 });\n47:         await this.emailInput.fill(email);\n48:         await this.passwordInput.fill(password);\n49:         await this.loginButton.click();\n50:         // Wait until the login page is gone (redirect to account dashboard or back to home)\n51:         await this.page.waitForURL(\n52:             (url) => !url.pathname.includes('/myaccount/login') && !url.pathname.includes('/login'),\n53:             { timeout: 30_000 },\n54:         );\n55:     }\n56: }"}}
