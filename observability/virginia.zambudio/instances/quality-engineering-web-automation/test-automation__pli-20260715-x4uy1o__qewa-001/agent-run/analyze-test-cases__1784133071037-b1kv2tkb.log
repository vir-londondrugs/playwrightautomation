{"event": "tool_result", "tool": "view", "is_error": false, "result": {"status": "success", "file": "/Users/virginia.zambudio/PlaywrightAutomation/pages/ProductDetailPage.ts", "content": "1: import { Page, Locator } from '@playwright/test';\n2: import { BasePage } from './BasePage';\n3: \n4: export class ProductDetailPage extends BasePage {\n5:     // ── Breadcrumbs ───────────────────────────────────────────────────────────\n6: \n7:     /** Full breadcrumbs nav */\n8:     readonly breadcrumbsNav: Locator;\n9: \n10:     /**\n11:      * Second-level breadcrumb link (first category after \"Home\").\n12:      * Breadcrumb structure: Home > Category > [SubCategory] > Product.\n13:      * The second <li> (index 1) holds the first category link.\n14:      */\n15:     readonly secondLevelBreadcrumb: Locator;\n16: \n17:     // ── Price ─────────────────────────────────────────────────────────────────\n18: \n19:     /** \"Our Price\" label */\n20:     readonly priceLabel: Locator;\n21: \n22:     /**\n23:      * Price value element showing the formatted price (e.g. \"$3.19\").\n24:      * UAT renders price in a <p class=\"text-2xl text-txtprimary\">.\n25:      */\n26:     readonly priceValue: Locator;\n27: \n28:     // ── Availability ──────────────────────────────────────────────────────────\n29: \n30:     /**\n31:      * The availability section container.\n32:      * Always visible on PDP; text changes based on store selection.\n33:      */\n34:     readonly availabilitySection: Locator;\n35: \n36:     /** \"Availability:\" heading label inside the section */\n37:     readonly availabilityLabel: Locator;\n38: \n39:     // ── Fulfillment options ───────────────────────────────────────────────────\n40: \n41:     /** In-Store Pickup fulfillment radio */\n42:     readonly inStorePickupRadio: Locator;\n43: \n44:     /** Ship to Home fulfillment radio */\n45:     readonly shipToHomeRadio: Locator;\n46: \n47:     /**\n48:      * Fulfillment label inside the Add to Cart button area.\n49:      * Shows \"for Ship to Home\", \"for Ship To My Store\", etc.\n50:      */\n51:     readonly fulfillmentLabel: Locator;\n52: \n53:     // ── Store selector (In-Store Pickup) ──────────────────────────────────────\n54: \n55:     /**\n56:      * \"Set your store\" link shown in the Availability section when no store is set.\n57:      * Opens `dialog#store-selector`.\n58:      */\n59:     readonly setYourStoreLink: Locator;\n60: \n61:     /** Store-selector modal dialog */\n62:     readonly storeSelectorDialog: Locator;\n63: \n64:     /** Postal code / city search input inside the store selector dialog */\n65:     readonly storeSelectorSearchInput: Locator;\n66: \n67:     /** \"SEARCH STORES\" submit button inside the store selector dialog */\n68:     readonly storeSelectorSearchButton: Locator;\n69: \n70:     /**\n71:      * First \"Set Store\" button in the store selector results.\n72:      * UAT renders each result with a `button.primary-button` labelled \"Set Store\".\n73:      * Index 0 is the close button; index 1 onward are the store result CTA buttons.\n74:      */\n75:     readonly firstSetStoreButton: Locator;\n76: \n77:     // ── Postal code modal (Ship to Home) ──────────────────────────────────────\n78: \n79:     /**\n80:      * \"Change Postal Code\" link inside the Ship to Home section.\n81:      * Opens `dialog.modal` (a daisyUI `<dialog>`) for entering a delivery postal code.\n82:      */\n83:     readonly changePostalCodeLink: Locator;\n84: \n85:     /** Delivery location modal dialog (daisyUI: `<dialog class=\"modal\">`) */\n86:     readonly deliveryLocationModal: Locator;\n87: \n88:     /** Postal code text input inside the delivery location modal */\n89:     readonly postalCodeInput: Locator;\n90: \n91:     /**\n92:      * \"UPDATE DELIVERY LOCATION\" submit button in the delivery location modal.\n93:      * Identified by its `data-label` attribute which was confirmed on live UAT.\n94:      */\n95:     readonly updateDeliveryLocationButton: Locator;\n96: \n97:     // ── Add to Cart ───────────────────────────────────────────────────────────\n98: \n99:     /** Add to Cart primary CTA button */\n100:     readonly addToCartButton: Locator;\n101: \n102:     /**\n103:      * \"View Cart & Checkout\" confirmation button that appears after a successful\n104:      * Add to Cart action on the product page.\n105:      */\n106:     readonly viewCartAndCheckoutButton: Locator;\n107: \n108:     // ── Mini cart badge ───────────────────────────────────────────────────────\n109: \n110:     /**\n111:      * Mini cart badge counter element inside the cart icon header button.\n112:      * Shows the current number of items in the cart.\n113:      */\n114:     readonly miniCartBadge: Locator;\n115: \n116:     // ── Wishlist ──────────────────────────────────────────────────────────────\n117: \n118:     /**\n119:      * Heart/wishlist icon button on the PDP.\n120:      * Clicking this when authenticated adds the product to the user's wishlist.\n121:      */\n122:     readonly wishlistButton: Locator;\n123: \n124:     constructor(page: Page) {\n125:         super(page);\n126: \n127:         // Breadcrumbs\n128:         this.breadcrumbsNav = page.locator('nav.breadcrumbs');\n129:         this.secondLevelBreadcrumb = page.locator('nav.breadcrumbs ul li:nth-child(2) a');\n130: \n131:         // Price\n132:         this.priceLabel = page.locator('main section h3').filter({ hasText: /our price/i });\n133:         this.priceValue = page.locator('main section p.text-2xl').first();\n134: \n135:         // Availability\n136:         this.availabilitySection = page.locator('main section').filter({ hasText: /Availability:/i }).first();\n137:         this.availabilityLabel = page.locator('main section h4').filter({ hasText: /Availability:/i }).first();\n138: \n139:         // Fulfillment radios\n140:         this.inStorePickupRadio = page.locator('input[aria-label=\"Product Ship to Store Pickup Fulfillment Type\"]');\n141:         this.shipToHomeRadio = page.locator('input[aria-label=\"Product Ship To Home Fulfillment Type\"]');\n142:         this.fulfillmentLabel = page.locator('span#fulfillment-label');\n143: \n144:         // Store selector\n145:         this.setYourStoreLink = page.locator('p.cursor-pointer.text-primary').filter({ hasText: /set your store/i }).first();\n146:         this.storeSelectorDialog = page.locator('dialog#store-selector');\n147:         this.storeSelectorSearchInput = page.locator('dialog#store-selector input[name=\"searchTerm\"]');\n148:         // Primary buttons inside the dialog: index 0 = SEARCH STORES, index 1+ = Set Store per result\n149:         this.storeSelectorSearchButton = page.locator('dialog#store-selector button.primary-button').first();\n150:         this.firstSetStoreButton = page.locator('dialog#store-selector button.primary-button').nth(1);\n151: \n152:         // Delivery location modal (Ship to Home postal code)\n153:         this.changePostalCodeLink = page.locator('p.cursor-pointer.text-primary').filter({ hasText: /change postal code/i }).first();\n154:         this.deliveryLocationModal = page.locator('dialog.modal');\n155:         this.postalCodeInput = page.locator('input[name=\"zipCode\"]');\n156:         this.updateDeliveryLocationButton = page.locator('button[data-label=\"update delivery location\"]');\n157: \n158:         // Add to Cart\n159:         this.addToCartButton = page.locator('button[aria-label=\"Add to cart button\"]');\n160:         this.viewCartAndCheckoutButton = page.locator('button', { hasText: 'View Cart & Checkout' });\n161: \n162:         // Mini cart badge (two exist in DOM for responsive breakpoints; first is sufficient)\n163:         this.miniCartBadge = page.locator('button[aria-label=\"Show Mini Cart Items\"] div[class*=\"bottom-1\"]').first();\n164: \n165:         // Wishlist\n166:         this.wishlistButton = page.locator('button[aria-label=\"Add product to wishlist heart button\"]');\n167:     }\n168: \n169:     // ── Lifecycle helpers ─────────────────────────────────────────────────────\n170: \n171:     /**\n172:      * Waits for the Product Detail Page to be fully loaded and interactive.\n173:      * Waits for the product H1 heading to be visible, then simulates a body\n174:      * click to unblock Next.js / Builder.io hydration stalls.\n175:      * Call after every navigation to the PDP.\n176:      */\n177:     async waitForPdp(): Promise<void> {\n178:         await this.page.locator('h1').first().waitFor({ state: 'visible', timeout: 15_000 });\n179:         await this.page.locator('body').click({ force: true });\n180:         await this.page.waitForTimeout(500);\n181:     }\n182: \n183:     /**\n184:      * Reads and returns the `href` attribute of the second-level breadcrumb link.\n185:      * Used to validate the expected navigation target before clicking.\n186:      */\n187:     async getBreadcrumbHref(): Promise<string> {\n188:         await this.secondLevelBreadcrumb.waitFor({ state: 'visible', timeout: 10_000 });\n189:         return (await this.secondLevelBreadcrumb.getAttribute('href') ?? '').trim();\n190:     }\n191: \n192:     /**\n193:      * Clicks the second-level breadcrumb link and waits for navigation to a\n194:      * category URL pattern (/category/).\n195:      */\n196:     async clickSecondBreadcrumb(): Promise<void> {\n197:         await this.secondLevelBreadcrumb.waitFor({ state: 'visible', timeout: 10_000 });\n198:         await this.secondLevelBreadcrumb.click();\n199:         await this.page.waitForURL(/\\/category\\//, { timeout: 15_000 });\n200:     }\n201: \n202:     /**\n203:      * Returns the text content of the price value element.\n204:      * Expected format: $X.XX (e.g. \"$3.19\", \"$12.49\").\n205:      */\n206:     async getPriceText(): Promise<string> {\n207:         await this.priceValue.waitFor({ state: 'visible', timeout: 10_000 });\n208:         return (await this.priceValue.textContent() ?? '').trim();\n209:     }\n210: \n211:     /**\n212:      * Ensures the Ship to Home fulfillment radio is selected.\n213:      * If not already checked, clicks it and waits for confirmation.\n214:      * Ship to Home is the default option; this method handles cases where\n215:      * In-Store Pickup may have been activated by a prior interaction.\n216:      */\n217:     async ensureShipToHomeSelected(): Promise<void> {\n218:         const isChecked = await this.shipToHomeRadio.isChecked().catch(() => false);\n219:         if (!isChecked) {\n220:             await this.shipToHomeRadio.click();\n221:         }\n222:         await this.page.waitForFunction(\n223:             (selector: string) => {\n224:                 const el = document.querySelector<HTMLInputElement>(selector);\n225:                 return el !== null && el.checked;\n226:             },\n227:             'input[aria-label=\"Product Ship To Home Fulfillment Type\"]',\n228:             { timeout: 10_000 }\n229:         );\n230:     }\n231: \n232:     /**\n233:      * Clicks the wishlist heart button to add (or toggle) the current product\n234:      * in the authenticated user's wishlist.\n235:      * Requires the user to be authenticated before calling.\n236:      */\n237:     async clickWishlist(): Promise<void> {\n238:         await this.wishlistButton.waitFor({ state: 'visible', timeout: 10_000 });\n239:         await this.wishlistButton.click();\n240:     }\n241: \n242:     // ── Cart / Mini cart helpers ───────────────────────────────────────────────\n243: \n244:     /**\n245:      * Reads the current mini cart badge count.\n246:      * Returns 0 when the badge element is not yet visible.\n247:      */\n248:     async getMiniCartCount(): Promise<number> {\n249:         try {\n250:             const text = await this.miniCartBadge.textContent({ timeout: 5_000 });\n251:             return parseInt(text?.trim() ?? '0', 10) || 0;\n252:         } catch {\n253:             return 0;\n254:         }\n255:     }\n256: \n257:     /**\n258:      * Opens the store selector dialog and waits for it to be visible.\n259:      *\n260:      * Two states are handled:\n261:      *   1. No store set yet  -- a \"Set your store\" link is visible.\n262:      *   2. Store already set -- the site (e.g. via geolocation on Firefox/WebKit)\n263:      *      pre-selects a store, replacing the \"Set your store\" link with\n264:      *      \"Check Availability at other stores\". Clicking that link also opens\n265:      *      the `dialog#store-selector` so the rest of the flow is identical.\n266:      *\n267:      * Scrolls to the fulfillment section first to ensure intersection-observer\n268:      * elements are mounted before waiting.\n269:      */\n270:     async openStoreSelectorDialog(): Promise<void> {\n271:         // Scroll the fulfillment area into view so lazy-rendered elements mount.\n272:         await this.inStorePickupRadio\n273:             .scrollIntoViewIfNeeded({ timeout: 10_000 })\n274:             .catch(() => undefined);\n275: \n276:         // Allow a brief moment for intersection-observer elements to mount after\n277:         // the scroll, especially on Firefox and WebKit which hydrate more slowly.\n278:         await this.page.waitForTimeout(1_500);\n279: \n280:         const checkAvailabilityLink = this.page\n281:             .locator('p.cursor-pointer')\n282:             .filter({ hasText: /check availability at other stores/i })\n283:             .first();\n284: \n285:         // Try \"Set your store\" first (no store set). locator.isVisible() does NOT\n286:         // accept a timeout option -- it returns immediately. Use waitFor with a\n287:         // short timeout inside a try/catch so we genuinely wait up to 5 s before\n288:         // falling back to \"Check Availability at other stores\" (store already set).\n289:         let setStoreVisible = false;\n290:         try {\n291:             await this.setYourStoreLink.waitFor({ state: 'visible', timeout: 5_000 });\n292:             setStoreVisible = true;\n293:         } catch {\n294:             setStoreVisible = false;\n295:         }\n296: \n297:         if (setStoreVisible) {\n298:             await this.setYourStoreLink.click();\n299:         } else {\n300:             await checkAvailabilityLink.waitFor({ state: 'visible', timeout: 15_000 });\n301:             await checkAvailabilityLink.click();\n302:         }\n303: \n304:         await this.storeSelectorDialog.waitFor({ state: 'visible', timeout: 10_000 });\n305:     }\n306: \n307:     /**\n308:      * Searches for stores by postal code/city in the store selector dialog\n309:      * and waits for search results to appear (first \"Set Store\" button visible).\n310:      */\n311:     async searchStores(postalCode: string): Promise<void> {\n312:         await this.storeSelectorSearchInput.waitFor({ state: 'visible', timeout: 10_000 });\n313:         await this.storeSelectorSearchInput.fill(postalCode);\n314:         await this.storeSelectorSearchButton.click();\n315:         await this.firstSetStoreButton.waitFor({ state: 'visible', timeout: 15_000 });\n316:     }\n317: \n318:     /**\n319:      * Selects the first store from the search results and waits for the dialog\n320:      * to close, confirming the store has been set.\n321:      */\n322:     async selectFirstStore(): Promise<void> {\n323:         await this.firstSetStoreButton.waitFor({ state: 'visible', timeout: 10_000 });\n324:         await this.firstSetStoreButton.click();\n325:         await this.storeSelectorDialog.waitFor({ state: 'hidden', timeout: 10_000 });\n326:     }\n327: \n328:     /**\n329:      * Opens the delivery location modal (via \"Change Postal Code\" link) and waits\n330:      * for the postal code input to be ready.\n331:      */\n332:     async openDeliveryLocationModal(): Promise<void> {\n333:         await this.changePostalCodeLink.waitFor({ state: 'visible', timeout: 15_000 });\n334:         await this.changePostalCodeLink.click();\n335:         await this.postalCodeInput.waitFor({ state: 'visible', timeout: 10_000 });\n336:     }\n337: \n338:     /**\n339:      * Fills in the postal code and submits the delivery location modal.\n340:      * Waits for the modal to close after submission.\n341:      */\n342:     async setDeliveryPostalCode(postalCode: string): Promise<void> {\n343:         await this.postalCodeInput.fill(postalCode);\n344:         await this.updateDeliveryLocationButton.click();\n345:         // Modal closes programmatically; wait for it to be removed/hidden\n346:         await this.deliveryLocationModal.waitFor({ state: 'hidden', timeout: 10_000 }).catch(() => {\n347:             // Some renders close via CSS; fallback — just wait briefly\n348:         });\n349:     }\n350: \n351:     /**\n352:      * Adds the current product to the cart and waits for the \"View Cart & Checkout\"\n353:      * confirmation button to appear, which confirms a successful add.\n354:      */\n355:     async addToCart(): Promise<void> {\n356:         await this.addToCartButton.waitFor({ state: 'visible', timeout: 10_000 });\n357:         await this.addToCartButton.click();\n358:         await this.viewCartAndCheckoutButton.waitFor({ state: 'visible', timeout: 20_000 });\n359:     }\n360: }"}}
