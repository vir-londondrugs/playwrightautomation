ectorDialog();\n176:         });\n177: \n178:         await test.step('Search for stores using postal code V6B 1A1', async () => {\n179:             await pdpPage.searchStores(pdpData.postalCode);\n180:         });\n181: \n182:         await test.step('Select the first store from results', async () => {\n183:             await pdpPage.selectFirstStore();\n184:         });\n185: \n186:         await test.step('Verify In-Store Pickup is now selected (fulfillment changed)', async () => {\n187:             // After selecting a store, In-Store Pickup radio is checked automatically\n188:             await pdpPage.inStorePickupRadio.waitFor({ state: 'attached', timeout: 30_000 });\n189:             await expect(pdpPage.inStorePickupRadio).toBeChecked({ timeout: 30_000 });\n190:         });\n191: \n192:         await test.step('Click ADD TO CART with In-Store Pickup fulfillment', async () => {\n193:             await pdpPage.addToCart();\n194:         });"}}
