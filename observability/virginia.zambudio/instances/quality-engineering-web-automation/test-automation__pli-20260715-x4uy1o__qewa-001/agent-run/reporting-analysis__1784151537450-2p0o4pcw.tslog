[18:40:14] {"event": "tool_call", "tool": "bash", "args": {"command": "cd /Users/virginia.zambudio/PlaywrightAutomation && node -e \"\nconst fs = require('fs');\nconst report = JSON.parse(fs.readFileSync('artifacts/outputs/quality-engineering-web-automation/test-execution-report.json','utf8'));\n\nconst stats = report.stats;\nconsole.log('=== STATS ===');\nconsole.log(JSON.stringify(stats, null, 2));\n\n// Suites summary\nconst suites = report.suites || [];\nlet passed = 0, failed = 0, skipped = 0, flaky = 0;\nconst failures = [];\nconst allTests = [];\n\nfunction processTests(suite, file) {\n  (suite.specs || []).forEach(spec => {\n    spec.tests.forEach(test => {\n      const result = test.results[0] || {};\n      const status = result.status;\n      const tcId = spec.title.match(/TC-\\d+/)?.[0] || 'unknown';\n      const entry = {\n        title: spec.title,\n        tcId,\n        status,\n        file,\n        browsers: [test.projectName],\n        error: result.error?.message?.split('\\n')[0] || null\n      };\n      allTests.push(entry);\n      if (status === 'passed') passed++;\n      else if (status === 'failed' || status === 'timedOut') { failed++; failures.push(entry); }\n      else if (status === 'skipped') skipped++;\n    });\n  });\n  (suite.suites || []).forEach(s => processTests(s, file || s.title));\n}\n\nsuites.forEach(s => processTests(s, s.title));\nconsole.log('\\n=== SUMMARY ===');\nconsole.log('Passed:', passed, 'Failed:', failed, 'Skipped:', skipped);\nconsole.log('\\n=== FAILURES ===');\nfailures.forEach(f => console.log(f.tcId, f.browsers, f.title.slice(0,60), '|', f.error?.slice(0,80)));\n\" 2>&1"}}
