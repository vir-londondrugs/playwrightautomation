[18:44:16] {"event": "tool_call", "tool": "bash", "args": {"command": "cd /Users/virginia.zambudio/PlaywrightAutomation && node -e \"\nconst fs = require('fs');\nconst report = JSON.parse(fs.readFileSync('artifacts/outputs/quality-engineering-web-automation/test-execution-report.json','utf8'));\n\nfunction collectSpecs(suite, results, file) {\n  (suite.specs || []).forEach(spec => {\n    spec.tests.forEach(test => {\n      const r = test.results[0] || {};\n      results.push({ title: spec.title, project: test.projectName, status: r.status, duration: r.duration, file });\n    });\n  });\n  (suite.suites || []).forEach(s => collectSpecs(s, results, file || s.title));\n}\nconst results = [];\n(report.suites || []).forEach(s => collectSpecs(s, results, s.title));\n\n// Group by file\nconst byFile = {};\nresults.forEach(r => {\n  if (!byFile[r.file]) byFile[r.file] = { passed:0, failed:0, tcs: new Set() };\n  const m = r.title.match(/TC-\\d+|FTC_\\d+_\\d+/);\n  if (m) byFile[r.file].tcs.add(m[0]);\n  if (r.status === 'passed') byFile[r.file].passed++;\n  else byFile[r.file].failed++;\n});\nObject.entries(byFile).forEach(([f,v]) => {\n  console.log(f + ': passed=' + v.passed + ' failed=' + v.failed + ' unique_tcs=' + v.tcs.size + ' tcs=' + [...v.tcs].join(','));\n});\n\" 2>&1"}}
