[18:40:52] {"event": "tool_result", "tool": "view", "is_error": false, "result": {"status": "success", "file": "/Users/virginia.zambudio/PlaywrightAutomation/tests/home-page.spec.ts", "content": "395:             await expect(homePage.flyersLink).toHaveAttribute('href', headerNav.flyers.href);\n396:         });\n397: \n398:         await test.step('Verify \"Gift Registry\" link is visible and has correct href', async () => {\n399:             await homePage.giftRegistryLink.waitFor({ state: 'visible', timeout: 30_000 });\n400:             await expect(homePage.giftRegistryLink).toHaveAttribute('href', headerNav.giftRegistry.href);\n401:         });\n402:     }\n403: );\n404: \n405: // ---------------------------------------------------------------------------\n406: // TC-83232  Home Page — Newsletter signup in footer submits and redirects\n407: // ADO TC: 83232 | Priority: P1 | Type: Positive\n408: // The SIGN UP button submits via client-side navigation to:\n409: //   /enewsletter-settings?email=<encoded_email>\n410: // No confirmation message is shown on the homepage itself.\n411: // Verification: URL matches /enewsletter-settings after submit.\n412: // ---------------------------------------------------------------------------\n413: test(\n414:     'TC-83232 — Newsletter signup in footer accepts valid email and redirects to confirmation @newsletter @footer',\n415:     async ({ page }) => {\n416:         // Override the global 60 s timeout: Builder.io networkidle can take 30 s,\n417:         // the incremental scroll loop ~20 s, and the final waitFor 45 s. 180 s is safe.\n418:         test.setTimeout(180_000);\n419: \n420:         const homePage = new HomePage(page);\n421:         const { newsletter } = homePageData;\n422: \n423:         await test.step('Navigate to homepage', async () => {\n424:             await homePage.navigate(homePageData.urls.home);\n425:         });\n426: \n427:         await test.step('Scroll to footer newsletter form', async () => {\n428:             // The newsletter section is Builder.io-driven and is only rendered\n429:             // once its placeholder element enters the viewport (IntersectionObserver).\n430:             // A single jump to document.body.scrollHeight does NOT work because the\n431:             // page height at load time is small (~285px) — the newsletter placeholder\n432:             // is far below and the IntersectionObserver never fires.\n433:             //\n434:             // Strategy: incremental scrolling in viewport-height steps to ensure\n435:             // every Builder.io section's IntersectionObserver fires as the viewport\n436:             // passes over it. Between steps we wait 800 ms so lazy fetches complete.\n437:             // After the loop, fall back to scrollIntoViewIfNeeded + a final waitFor.\n438: \n439:             // First, let the page finish its initial network activity.\n440:             await page.waitForLoadState('networkidle', { timeout: 30_000 }).catch(() => {});\n441:             await page.waitForTimeout(1_000);\n442: \n443:             const viewportHeight = page.viewportSize()?.height ?? 800;\n444:             let scrollPosition = 0;\n445: \n446:             // Scroll in viewport-sized increments for up to 20 passes.\n447:             for (let pass = 0; pass < 20; pass++) {\n448:                 // Check if the element is already visible before scrolling further.\n449:                 const alreadyVisible = await homePage.newsletterEmailInput\n450:                     .isVisible()\n451:                     .catch(() => false);\n452:                 if (alreadyVisible) break;\n453: \n454:                 scrollPosition += viewportHeight;"}}
