[18:44:00] {"event": "tool_call", "tool": "bash", "args": {"command": "cd /Users/virginia.zambudio/PlaywrightAutomation && node -e \"\nconst fs = require('fs');\nconst report = JSON.parse(fs.readFileSync('artifacts/outputs/quality-engineering-web-automation/test-execution-report.json','utf8'));\n\nconst stats = report.stats;\nconsole.log('Start:', stats.startTime);\nconsole.log('Duration ms:', stats.duration);\nconsole.log('Expected (passed):', stats.expected);\nconsole.log('Unexpected (failed):', stats.unexpected);\nconsole.log('Skipped:', stats.skipped);\nconsole.log('Flaky:', stats.flaky);\n\n// Collect test titles from suites\nfunction collectSpecs(suite, results) {\n  (suite.specs || []).forEach(spec => {\n    spec.tests.forEach(test => {\n      const r = test.results[0] || {};\n      results.push({ title: spec.title, project: test.projectName, status: r.status, duration: r.duration });\n    });\n  });\n  (suite.suites || []).forEach(s => collectSpecs(s, results));\n}\nconst results = [];\n(report.suites || []).forEach(s => collectSpecs(s, results));\nconsole.log('Total test results collected:', results.length);\n\n// Group by TC id\nconst byTc = {};\nresults.forEach(r => {\n  const m = r.title.match(/TC-\\d+/);\n  const tc = m ? m[0] : 'other';\n  if (!byTc[tc]) byTc[tc] = [];\n  byTc[tc].push({ project: r.project, status: r.status, duration: r.duration });\n});\nconsole.log('TC IDs found:', Object.keys(byTc).join(', '));\n\n// Unique spec titles\nconst specTitles = [...new Set(results.map(r => r.title))];\nconsole.log('Unique specs:', specTitles.length);\nspecTitles.forEach(t => console.log(' -', t.slice(0,80)));\n\" 2>&1"}}
