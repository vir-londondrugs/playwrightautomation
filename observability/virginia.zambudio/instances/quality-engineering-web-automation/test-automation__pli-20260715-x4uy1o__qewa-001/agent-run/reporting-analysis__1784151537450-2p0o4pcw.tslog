[18:40:43] {"event": "tool_result", "tool": "view", "is_error": false, "result": {"status": "success", "file": "/Users/virginia.zambudio/PlaywrightAutomation/pages/ProductDetailPage.ts", "content": "100:     readonly addToCartButton: Locator;\n101: \n102:     /**\n103:      * \"View Cart & Checkout\" confirmation button that appears after a successful\n104:      * Add to Cart action on the product page.\n105:      */\n106:     readonly viewCartAndCheckoutButton: Locator;\n107: \n108:     // ── Mini cart badge ───────────────────────────────────────────────────────\n109: \n110:     /**\n111:      * Mini cart badge counter element inside the cart icon header button.\n112:      * Shows the current number of items in the cart.\n113:      */\n114:     readonly miniCartBadge: Locator;\n115: \n116:     // ── Wishlist ──────────────────────────────────────────────────────────────\n117: \n118:     /**\n119:      * Heart/wishlist icon button on the PDP.\n120:      * Clicking this when authenticated adds the product to the user's wishlist.\n121:      */\n122:     readonly wishlistButton: Locator;\n123: \n124:     constructor(page: Page) {\n125:         super(page);\n126: \n127:         // Breadcrumbs\n128:         this.breadcrumbsNav = page.locator('nav.breadcrumbs');\n129:         this.secondLevelBreadcrumb = page.locator('nav.breadcrumbs ul li:nth-child(2) a');\n130: \n131:         // Price\n132:         this.priceLabel = page.locator('main section h3').filter({ hasText: /our price/i });\n133:         this.priceValue = page.locator('main section p.text-2xl').first();\n134: \n135:         // Availability\n136:         this.availabilitySection = page.locator('main section').filter({ hasText: /Availability:/i }).first();\n137:         this.availabilityLabel = page.locator('main section h4').filter({ hasText: /Availability:/i }).first();\n138: \n139:         // Fulfillment radios\n140:         this.inStorePickupRadio = page.locator('input[aria-label=\"Product Ship to Store Pickup Fulfillment Type\"]');\n141:         this.shipToHomeRadio = page.locator('input[aria-label=\"Product Ship To Home Fulfillment Type\"]');\n142:         this.fulfillmentLabel = page.locator('span#fulfillment-label');\n143: \n144:         // Store selector\n145:         this.setYourStoreLink = page.locator('p.cursor-pointer.text-primary').filter({ hasText: /set your store/i }).first();\n146:         this.storeSelectorDialog = page.locator('dialog#store-selector');\n147:         this.storeSelectorSearchInput = page.locator('dialog#store-selector input[name=\"searchTerm\"]');\n148:         // Primary buttons inside the dialog: index 0 = SEARCH STORES, index 1+ = Set Store per result\n149:         this.storeSelectorSearchButton = page.locator('dialog#store-selector button.primary-button').first();\n150:         this.firstSetStoreButton = page.locator('dialog#store-selector button.primary-button').nth(1);\n151: \n152:         // Delivery location modal (Ship to Home postal code)\n153:         this.changePostalCodeLink = page.locator('p.cursor-pointer.text-primary').filter({ hasText: /change postal code/i }).first();\n154:         this.deliveryLocationModal = page.locator('dialog.modal');\n155:         this.postalCodeInput = page.locator('input[name=\"zipCode\"]');\n156:         this.updateDeliveryLocationButton = page.locator('button[data-label=\"update delivery location\"]');\n157: \n158:         // Add to Cart\n159:         this.addToCartButton = page.locator('button[aria-label=\"Add to cart button\"]');\n160:         this.viewCartAndCheckoutButton = page.locator('button', { hasText: 'View Cart & Checkout' });\n161: \n162:         // Mini cart badge (two exist in DOM for responsive breakpoints; first is sufficient)\n163:         this.miniCartBadge = page.locator('button[aria-label=\"Show Mini Cart Items\"] div[class*=\"bottom-1\"]').first();\n164: \n165:         // Wishlist\n166:         this.wishlistButton = page.locator('button[aria-label=\"Add product to wishlist heart button\"]');\n167:     }\n168: \n169:     // ── Lifecycle helpers ─────────────────────────────────────────────────────\n170: \n171:     /**\n172:      * Waits for the Product Detail Page to be fully loaded and interactive.\n173:      * Waits for the product H1 heading to be visible, then simulates a body\n174:      * click to unblock Next.js / Builder.io hydration stalls.\n175:      * Call after every navigation to the PDP.\n176:      */\n177:     async waitForPdp(): Promise<void> {\n178:         await this.page.locator('h1').first().waitFor({ state: 'visible', timeout: 15_000 });\n179:         await this.page.locator('body').click({ force: true });\n180:         await this.page.waitForTimeout(500);\n181:     }\n182: \n183:     /**\n184:      * Reads and returns the `href` attribute of the second-level breadcrumb link.\n185:      * Used to validate the expected navigation target before clicking.\n186:      */\n187:     async getBreadcrumbHref(): Promise<string> {\n188:         await this.secondLevelBreadcrumb.waitFor({ state: 'visible', timeout: 10_000 });\n189:         return (await this.secondLevelBreadcrumb.getAttribute('href') ?? '').trim();\n190:     }\n191: \n192:     /**\n193:      * Clicks the second-level breadcrumb link and waits for navigation to a\n194:      * category URL pattern (/category/).\n195:      */\n196:     async clickSecondBreadcrumb(): Promise<void> {\n197:         await this.secondLevelBreadcrumb.waitFor({ state: 'visible', timeout: 10_000 });\n198:         await this.secondLevelBreadcrumb.click();\n199:         await this.page.waitForURL(/\\/category\\//, { timeout: 15_000 });\n200:     }\n201: \n202:     /**\n203:      * Returns the text content of the price value element.\n204:      * Expected format: $X.XX (e.g. \"$3.19\", \"$12.49\").\n205:      */\n206:     async getPriceText(): Promise<string> {\n207:         await this.priceValue.waitFor({ state: 'visible', timeout: 10_000 });\n208:         return (await this.priceValue.textContent() ?? '').trim();\n209:     }\n210: \n211:     /**\n212:      * Ensures the Ship to Home fulfillment radio is selected.\n213:      * If not already checked, clicks it and waits for confirmation.\n214:      * Ship to Home is the default option; this method handles cases where\n215:      * In-Store Pickup may have been activated by a prior interaction.\n216:      */\n217:     async ensureShipToHomeSelected(): Promise<void> {\n218:         const isChecked = await this.shipToHomeRadio.isChecked().catch(() => false);\n219:         if (!isChecked) {\n220:             await this.shipToHomeRadio.click();\n221:         }\n222:         await this.page.waitForFunction(\n223:             (selector: string) => {\n224:                 const el = document.querySelector<HTMLInputElement>(selector);\n225:                 return el !== null && el.checked;\n226:             },\n227:             'input[aria-label=\"Product Ship To Home Fulfillment Type\"]',\n228:             { timeout: 10_000 }\n229:         );\n230:     }\n231: \n232:     /**\n233:      * Clicks the wishlist heart button to add (or toggle) the current product\n234:      * in the authenticated user's wishlist.\n235:      * Requires the user to be authenticated before calling.\n236:      */\n237:     async clickWishlist(): Promise<void> {\n238:         await this.wishlistButton.waitFor({ state: 'visible', timeout: 10_000 });\n239:         await this.wishlistButton.click();\n240:     }\n241: \n242:     // ── Cart / Mini cart helpers ───────────────────────────────────────────────\n243: \n244:     /**\n245:      * Reads the current mini cart badge count.\n246:      * Returns 0 when the badge element is not yet visible.\n247:      */\n248:     async getMiniCartCount(): Promise<number> {\n249:         try {\n250:             const text = await this.miniCartBadge.textContent({ timeout: 5_000 });\n251:             return parseInt(text?.trim() ?? '0', 10) || 0;\n252:         } catch {\n253:             return 0;\n254:         }\n255:     }\n256: \n257:     /**\n258:      * Opens the store selector dialog and waits for it to be visible.\n259:      *\n260:      * Two states are handled:\n261:      *   1. No store set yet  -- a \"Set your store\" link is visible.\n262:      *   2. Store already set -- the site (e.g. via geolocation on Firefox/WebKit)\n263:      *      pre-selects a store, replacing the \"Set your store\" link with\n264:      *      \"Check Availability at other stores\". Clicking that link also opens\n265:      *      the `dialog#store-selector` so the rest of the flow is identical.\n266:      *\n267:      * Scrolls to the fulfillment section first to ensure intersection-observer\n268:      * elements are mounted before waiting.\n269:      *\n270:      * Firefox / WebKit note: `inStorePickupRadio` may not be present on products\n271:      * that only offer Ship to Home. We use a two-step scroll strategy:\n272:      *   1. Try scrollIntoViewIfNeeded on the pickup radio (silently ignored if missing).\n273:      *   2. Fallback: scroll to ~60 % of the page height to bring the fulfillment\n274:      *      section — and with it the \"Set your store\" link — into the viewport and\n275:      *      trigger any remaining IntersectionObservers.\n276:      */\n277:     async openStoreSelectorDialog(): Promise<void> {\n278:         // Step 1: attempt to scroll via the In-Store Pickup radio (may not exist).\n279:         await this.inStorePickupRadio"}}
