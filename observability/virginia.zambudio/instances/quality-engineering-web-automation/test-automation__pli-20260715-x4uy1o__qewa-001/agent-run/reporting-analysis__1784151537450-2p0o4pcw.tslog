[18:44:09] {"event": "tool_call", "tool": "bash", "args": {"command": "cd /Users/virginia.zambudio/PlaywrightAutomation && node -e \"\nconst fs = require('fs');\nconst report = JSON.parse(fs.readFileSync('artifacts/outputs/quality-engineering-web-automation/test-execution-report.json','utf8'));\n\nfunction collectSpecs(suite, results) {\n  (suite.specs || []).forEach(spec => {\n    spec.tests.forEach(test => {\n      const r = test.results[0] || {};\n      results.push({ title: spec.title, project: test.projectName, status: r.status, duration: r.duration });\n    });\n  });\n  (suite.suites || []).forEach(s => collectSpecs(s, results));\n}\nconst results = [];\n(report.suites || []).forEach(s => collectSpecs(s, results));\n\n// Per-project breakdown\nconst byProject = {};\nresults.forEach(r => {\n  if (!byProject[r.project]) byProject[r.project] = {passed:0, failed:0};\n  if (r.status === 'passed') byProject[r.project].passed++;\n  else byProject[r.project].failed++;\n});\nconsole.log('Per project:', JSON.stringify(byProject));\n\n// Duration stats\nconst durations = results.map(r => r.duration || 0);\nconst totalMs = durations.reduce((a,b)=>a+b,0);\nconst avgMs = totalMs / durations.length;\nconsole.log('Avg test duration ms:', Math.round(avgMs));\nconsole.log('Max test duration ms:', Math.max(...durations));\nconsole.log('Min test duration ms:', Math.min(...durations));\nconsole.log('Total wall clock duration s:', Math.round(report.stats.duration/1000));\n\n// Spec titles by TC\nconst specMap = {};\nfunction collectSpecMap(suite) {\n  (suite.specs || []).forEach(spec => {\n    const m = spec.title.match(/TC-\\d+/);\n    const tc = m ? m[0] : 'other';\n    if (!specMap[tc]) specMap[tc] = spec.title;\n  });\n  (suite.suites || []).forEach(s => collectSpecMap(s));\n}\n(report.suites || []).forEach(s => collectSpecMap(s));\nObject.keys(specMap).sort().forEach(k => console.log(k + ': ' + specMap[k].slice(0,80)));\n\" 2>&1"}}
