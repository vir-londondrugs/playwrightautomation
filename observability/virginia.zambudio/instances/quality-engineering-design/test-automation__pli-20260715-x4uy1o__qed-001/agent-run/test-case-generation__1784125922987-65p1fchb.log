esults', async () => {\n179:             await pdpPage.selectFirstStore();\n180:         });\n181: \n182:         await test.step('Verify In-Store Pickup is now selected (fulfillment changed)', async () => {\n183:             // After selecting a store, In-Store Pickup radio is checked automatically\n184:             await pdpPage.inStorePickupRadio.waitFor({ state: 'attached', timeout: 30_000 });\n185:             await expect(pdpPage.inStorePickupRadio).toBeChecked({ timeout: 30_000 });\n186:         });\n187: \n188:         await test.step('Click ADD TO CART with In-Store Pickup fulfillment', async () => {\n189:             await pdpPage.addToCart();\n190:         });\n191: \n192:         await test.step('Verify mini cart badge counter incremented by 1', async () => {\n193:             const countAfter = await pdpPage.getMiniCartCount();\n194:             expect(countAfter).toBe(countBefore + 1);"}}
