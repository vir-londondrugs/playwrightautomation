erver actions; wishlist operations POST to the\n281:             // current PDP URL with action payload, returning JSON with isSuccess: true.\n282:             // We wait for ANY POST to the current page URL that returns a 200 response.\n283:             const wishlistResponsePromise = page.waitForResponse(\n284:                 (response) =>\n285:                     response.request().method() === 'POST' &&\n286:                     response.url().includes('/products/') &&\n287:                     response.status() === 200,\n288:                 { timeout: 30_000 }\n289:             );\n290: \n291:             await pdpPage.wishlistButton.click();\n292: \n293:             // Wait for the API response confirming the wishlist action was processed\n294:             const response = await wishlistResponsePromise;\n295:             expect(response.status()).toBe(200);\n296: \n297:             // Optionally parse the response body to verify isSuccess: true\n298:             let body: string | null = null;\n299:             try {"}}
