ipToHomeRadio.isChecked().catch(() => false);\n219:         if (!isChecked) {\n220:             await this.shipToHomeRadio.click();\n221:         }\n222:         await this.page.waitForFunction(\n223:             (selector: string) => {\n224:                 const el = document.querySelector<HTMLInputElement>(selector);\n225:                 return el !== null && el.checked;\n226:             },\n227:             'input[aria-label=\"Product Ship To Home Fulfillment Type\"]',\n228:             { timeout: 10_000 }\n229:         );\n230:     }\n231: \n232:     /**\n233:      * Clicks the wishlist heart button to add (or toggle) the current product\n234:      * in the authenticated user's wishlist.\n235:      * Requires the user to be authenticated before calling.\n236:      */\n237:     async clickWishlist(): Promise<void> {\n238:         await this.wishlistButton.waitFor({ state: 'visible', timeout: 10_000 });\n239:         await this.wishlistButton.click();\n240:     }\n241: \n242:     // ── Cart / Mini cart helpers ───────────────────────────────────────────────\n243: \n244:     /**\n245:      * Reads the current mini cart badge count.\n246:      * Returns 0 when the badge element is not yet visible.\n247:      */\n248:     async getMiniCartCount(): Promise<number> {\n249:         try {\n250:             const text = await this.miniCartBadge.textContent({ timeout: 5_000 });\n251:             return parseInt(text?.trim() ?? '0', 10) || 0;\n252:         } catch {\n253:             return 0;\n254:         }\n255:     }\n256: \n257:     /**\n258:      * Opens the store selector dialog by clicking \"Set your store\" and waits\n259:      * for the dialog to be visible.\n260:      */\n261:     async openStoreSelectorDialog(): Promise<void> {\n262:         await this.setYourStoreLink.waitFor({ state: 'visible', timeout: 15_000 });\n263:         await this.setYourStoreLink.click();\n264:         await this.storeSelectorDialog.waitFor({ state: 'visible', timeout: 10_000 });\n