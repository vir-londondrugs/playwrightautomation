{"event": "tool_result", "tool": "view", "is_error": false, "result": {"status": "success", "file": "/Users/virginia.zambudio/PlaywrightAutomation/pages/BasePage.ts", "content": "1: import { Page } from '@playwright/test';\n2: \n3: /** Timeout (ms) to wait for the page to reach 'load' state before clicking to dismiss loaders */\n4: const LOAD_STATE_TIMEOUT_MS = 15_000;\n5: \n6: export class BasePage {\n7:     protected readonly page: Page;\n8: \n9:     constructor(page: Page) {\n10:         this.page = page;\n11:     }\n12: \n13:     async navigate(url: string): Promise<void> {\n14:         await this.page.goto(url);\n15:         await this.page.waitForLoadState('domcontentloaded');\n16:         await this.dismissLoadingIfStuck();\n17:     }\n18: \n19:     /**\n20:      * Waits for the page to fully load. If it stays stuck in a loading state\n21:      * beyond the threshold, clicks the page body to dismiss overlays/spinners\n22:      * and gives the page another chance to finish loading.\n23:      */\n24:     async dismissLoadingIfStuck(): Promise<void> {\n25:         try {\n26:             await this.page.waitForLoadState('load', { timeout: LOAD_STATE_TIMEOUT_MS });\n27:         } catch {\n28:             // Page did not reach 'load' state in time: click body to dismiss\n29:             // any blocking overlay or infinite spinner and wait once more\n30:             await this.page.locator('body').click({ force: true });\n31:             await this.page.waitForLoadState('domcontentloaded');\n32:         }\n33:     }\n34: }"}}
