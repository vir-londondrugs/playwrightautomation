{"event": "tool_result", "tool": "view", "is_error": false, "result": {"status": "success", "file": "/Users/virginia.zambudio/PlaywrightAutomation/pages/LoginPage.ts", "content": "1: import { Page, Locator } from '@playwright/test';\n2: import { BasePage } from './BasePage';\n3: \n4: export class LoginPage extends BasePage {\n5:     /** Email address input on the login form */\n6:     readonly emailInput: Locator;\n7: \n8:     /** Password input on the login form */\n9:     readonly passwordInput: Locator;\n10: \n11:     /** Login / Sign In submit button */\n12:     readonly loginButton: Locator;\n13: \n14:     constructor(page: Page) {\n15:         super(page);\n16:         this.emailInput = page.locator('input[name=\"email\"][type=\"email\"]').first();\n17:         this.passwordInput = page.locator('input[name=\"password\"][type=\"password\"]').first();\n18:         this.loginButton = page.locator('button[type=\"submit\"]').filter({ hasText: /login/i }).first();\n19:     }\n20: \n21:     /**\n22:      * Navigates to the My Account page (which redirects to the login form when\n23:      * the user is not authenticated) and logs in with the provided credentials.\n24:      * Waits for the URL to leave /myaccount/login as confirmation of success.\n25:      */\n26:     async login(email: string, password: string): Promise<void> {\n27:         await this.navigate('/myaccount');\n28:         await this.emailInput.waitFor({ state: 'visible', timeout: 15_000 });\n29:         await this.emailInput.fill(email);\n30:         await this.passwordInput.fill(password);\n31:         await this.loginButton.click();\n32:         // Wait until the login page is gone (redirect to account dashboard or back to home)\n33:         await this.page.waitForURL((url) => !url.pathname.includes('/myaccount/login') && !url.pathname.includes('/login'), {\n34:             timeout: 20_000,\n35:         });\n36:     }\n37: }"}}
