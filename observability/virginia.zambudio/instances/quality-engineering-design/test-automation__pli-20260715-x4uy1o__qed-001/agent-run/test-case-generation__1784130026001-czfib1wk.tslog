('Search for stores using postal code V6B 1A1', async () => {\n175:             await pdpPage.searchStores(pdpData.postalCode);\n176:         });\n177: \n178:         await test.step('Select the first store from results', async () => {\n179:             await pdpPage.selectFirstStore();\n180:         });\n181: \n182:         await test.step('Verify In-Store Pickup is now selected (fulfillment changed)', async () => {\n183:             // After selecting a store, In-Store Pickup radio is checked automatically\n184:             await pdpPage.inStorePickupRadio.waitFor({ state: 'attached', timeout: 30_000 });\n185:             await expect(pdpPage.inStorePickupRadio).toBeChecked({ timeout: 30_000 });\n186:         });\n187: \n188:         await test.step('Click ADD TO CART with In-Store Pickup fulfillment', async () => {\n189:             await pdpPage.addToCart();\n190:         });\n191: \n192:         await test.step('Verify mini cart badge counter incremented by 1', async () => {\n193:             const countAfter = await pdpPage.getMiniCartCount();\n194:             expect(countAfter).toBe(countBefore + 1);\n195:         });\n196:     }\n197: );\n198: \n199: // ---------------------------------------------------------------------------\n200: // TC-83239  PDP — Add to cart with Ship to Home using postal code V6B 1A1\n201: //           increments cart counter\n202: // ADO TC: 83239 | Priority: P1 | Type: Positive\n203: // ---------------------------------------------------------------------------\n204: test(\n205:     'TC-83239 — Add to cart with Ship to Home (postal V6B 1A1) increments cart counter @pdp @cart @ship-to-home',\n206:     async ({ page }) => {\n207:         const homePage = new HomePage(page);\n208:         const searchResultsPage = new SearchResultsPage(page);\n209:         const pdpPage = new ProductDetailPage(page);\n210: \n211:         await test.step('Navigate to a vitamins product detail page via search', async () => {\n212:             await navi