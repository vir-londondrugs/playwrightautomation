                 .isVisible()\n420:                     .catch(() => false);\n421:                 if (inputVisible) break;\n422:             }\n423:             await homePage.newsletterEmailInput.waitFor({ state: 'visible', timeout: 30_000 });\n424:         });\n425: \n426:         await test.step('Fill valid email in newsletter input', async () => {\n427:             await homePage.newsletterEmailInput.fill(newsletter.testEmail);\n428:         });\n429: \n430:         await test.step('Click SIGN UP button', async () => {\n431:             await homePage.newsletterSubmitButton.waitFor({ state: 'visible', timeout: 30_000 });\n432:             await homePage.newsletterSubmitButton.click();\n433:         });\n434: \n435:         await test.step('Verify page redirects to /enewsletter-settings', async () => {\n436:             // Submit triggers a client-side navigation to /enewsletter-settings?email=<email>.\n437:             // This confirms the form was accepted and the user is routed to the preferences page.\n438:             await page.waitForURL(newsletter.expectedRedirectUrlPattern, { timeout: 45_000 });\n439:             await expect(page).toHaveURL(newsletter.expectedRedirectUrlPattern);\n440:         });\n441:     }\n442: );"}}
