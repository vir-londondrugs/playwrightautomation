Kit which hydrate more slowly.\n", "│ +        await this.page.waitForTimeout(1_500);\n", "│ +\n", "│          const checkAvailabilityLink = this.page\n", "│              .locator('p.cursor-pointer')\n", "│              .filter({ hasText: /check availability at other stores/i })\n", "│              .first();\n", "│  \n", "│ -        // Try \"Set your store\" first (no store set). If it is not visible within\n", "│ -        // 3 s, fall back to \"Check Availability at other stores\" (store already set).\n", "│ -        const setStoreVisible = await this.setYourStoreLink\n", "│ -            .isVisible({ timeout: 3_000 })\n", "│ -            .catch(() => false);\n", "│ +        // Try \"Set your store\" first (no store set). locator.isVisible() does NOT\n", "│ +        // accept a timeout option -- it returns immediately. Use waitFor with a\n", "│ +        // short timeout inside a try/catch so we genuinely wait up to 5 s before\n", "│ +        // falling back to \"Check Availability at other stores\" (store already set).\n", "│ +        let setStoreVisible = false;\n", "│ +        try {\n", "│ +            await this.setYourStoreLink.waitFor({ state: 'visible', timeout: 5_000 });\n", "│ +            setStoreVisible = true;\n", "│ +        } catch {\n", "│ +            setStoreVisible = false;\n", "│ +        }\n", "│  \n", "│          if (setStoreVisible) {\n", "│              await this.setYourStoreLink.click();\n", "│          } else {\n", "│ -            await checkAvailabilityLink.waitFor({ state: 'visible', timeout: 12_000 });\n", "│ +            await checkAvailabilityLink.waitFor({ state: 'visible', timeout: 15_000 });\n", "│              await checkAvailabilityLink.click();\n", "│          }\n", "│  \n"]}}
